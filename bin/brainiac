#!/usr/bin/env ruby

require "English"
require "json"
require "optparse"
require "fileutils"
require "open3"
require "net/http"
require "uri"
require "time"

# Brainiac CLI - Register and manage projects with Brainiac server

BRAINIAC_ROOT = File.expand_path("..", __dir__)
require_relative "../lib/brainiac/version"
BRAINIAC_VERSION = Brainiac::VERSION

BRAINIAC_DIR = File.join(Dir.home, ".brainiac")
PROJECTS_FILE = File.join(BRAINIAC_DIR, "projects.json")
CONFIG_FILE = File.join(BRAINIAC_DIR, "config.json")
PID_FILE = File.join(BRAINIAC_DIR, "server.pid")

def ensure_brainiac_dir
  FileUtils.mkdir_p(BRAINIAC_DIR)
end

def load_projects
  return {} unless File.exist?(PROJECTS_FILE)

  JSON.parse(File.read(PROJECTS_FILE))
rescue JSON::ParserError
  {}
end

def save_projects(projects)
  ensure_brainiac_dir
  File.write(PROJECTS_FILE, JSON.pretty_generate(projects))
end

def load_config
  return {} unless File.exist?(CONFIG_FILE)

  JSON.parse(File.read(CONFIG_FILE))
rescue JSON::ParserError
  {}
end

def save_config(config)
  ensure_brainiac_dir
  File.write(CONFIG_FILE, JSON.pretty_generate(config))
end

# Resolve the default agent name: env var → brainiac.json → nil.
def default_agent_name
  return ENV["AI_AGENT_NAME"] if ENV["AI_AGENT_NAME"] && !ENV["AI_AGENT_NAME"].empty?

  brainiac_config_path = File.join(BRAINIAC_DIR, "brainiac.json")
  if File.exist?(brainiac_config_path)
    config = JSON.parse(File.read(brainiac_config_path))
    return config["default_agent"] if config["default_agent"]
  end

  nil
rescue JSON::ParserError
  nil
end

def find_server_pid
  # First check PID file
  if File.exist?(PID_FILE)
    pid = File.read(PID_FILE).strip.to_i
    return pid if pid.positive? && process_running?(pid)

    # Stale PID file
    File.delete(PID_FILE)

  end

  # Fallback: search for running receiver.rb process
  # Try multiple methods to find the process

  # Method 1: pgrep with full pattern
  output, status = Open3.capture2("pgrep", "-f", 'ruby.*receiver\.rb')
  if status.success? && !output.strip.empty?
    pids = output.strip.split("\n").map(&:to_i)
    return pids.first if pids.any?
  end

  # Method 2: ps + grep (more portable)
  output, status = Open3.capture2("ps", "aux")
  if status.success?
    output.each_line do |line|
      next unless line.include?("ruby") && line.include?("receiver.rb") && !line.include?("grep")

      # Extract PID (second column in ps aux output)
      parts = line.split
      pid = parts[1].to_i
      return pid if pid.positive? && process_running?(pid)
    end
  end

  nil
end

def process_running?(pid)
  Process.kill(0, pid)
  true
rescue Errno::ESRCH, Errno::EPERM
  false
end

def fetch_active_sessions
  uri = URI("http://localhost:4567/api/status")
  response = Net::HTTP.get_response(uri)
  return [] unless response.is_a?(Net::HTTPSuccess)

  data = JSON.parse(response.body)
  (data["sessions"] || data).select { |s| s["alive"] }
rescue StandardError
  []
end

# Notify the running server to reload configs (triggers agent lifecycle hooks).
# Silently does nothing if the server isn't running.
def notify_server_reload
  config = load_config
  server_url = config["server_url"] || "http://localhost:4567"
  uri = URI("#{server_url}/api/reload")
  http = Net::HTTP.new(uri.host, uri.port)
  http.open_timeout = 2
  http.read_timeout = 5
  request = Net::HTTP::Post.new(uri.path)
  http.request(request)
rescue StandardError
  nil
end

def wait_for_agents_to_finish
  sessions = fetch_active_sessions
  return true if sessions.empty?

  agents = sessions.map { |s| s["agent"] || "Unknown" }
  puts "⏳ Waiting for #{sessions.size} active agent(s) to finish: #{agents.join(", ")}"
  puts "   (Ctrl+C to restart immediately)"

  begin
    loop do
      sleep 5
      sessions = fetch_active_sessions
      if sessions.empty?
        puts "✓ All agents finished."
        return true
      end
      agents = sessions.map { |s| s["agent"] || "Unknown" }
      elapsed = sessions.map { |s| s["elapsed_seconds"] || 0 }.max
      puts "   Still waiting... #{sessions.size} agent(s) active: #{agents.join(", ")} (#{elapsed}s)"
    end
  rescue Interrupt
    puts "\n⚡ Skipping wait, restarting now..."
    true
  end
end

def stop_server
  pid = find_server_pid

  unless pid
    puts "No running Brainiac server found."
    return false
  end

  puts "Stopping Brainiac server (PID: #{pid})..."

  # Also stop the monitor daemon
  daemon_pid_file = "/tmp/brainiac-daemon.pid"
  if File.exist?(daemon_pid_file)
    daemon_pid = File.read(daemon_pid_file).strip.to_i
    begin
      Process.kill("TERM", daemon_pid)
      puts "✓ Monitor daemon stopped (PID: #{daemon_pid})."
    rescue Errno::ESRCH
      # Already dead
    end
    File.delete(daemon_pid_file)
  end

  begin
    Process.kill("TERM", pid)

    # Wait up to 5 seconds for graceful shutdown
    5.times do
      sleep 2
      next if process_running?(pid)

      puts "✓ Server stopped."
      FileUtils.rm_f(PID_FILE)
      return true
    end

    # Force kill if still running
    puts "Server didn't stop gracefully, forcing..."
    Process.kill("KILL", pid)
    sleep 1

    FileUtils.rm_f(PID_FILE)
    puts "✓ Server stopped (forced)."
    true
  rescue Errno::ESRCH
    puts "✓ Server already stopped."
    FileUtils.rm_f(PID_FILE)
    true
  rescue Errno::EPERM
    puts "Error: Permission denied. Try running with sudo or check process ownership."
    false
  rescue StandardError => e
    puts "Error stopping server: #{e.message}"
    false
  end
end

def update_handler_config(name, enabled)
  brainiac_config_path = File.join(BRAINIAC_DIR, "brainiac.json")
  config = if File.exist?(brainiac_config_path)
             JSON.parse(File.read(brainiac_config_path))
           else
             {}
           end

  config["handlers"] ||= {}
  config["handlers"][name] = enabled
  File.write(brainiac_config_path, JSON.pretty_generate(config))

  action = enabled ? "enabled" : "disabled"
  puts "✓ Handler '#{name}' #{action}"
  puts "  Restart the server for changes to take effect: brainiac restart"
end

# After installing a plugin, load it and run its setup if it provides one.
# Only runs if the plugin defines .cli and responds to a "setup" subcommand via .configured?
def run_plugin_setup(name, local_path: nil)
  gem_name = "brainiac-#{name}"
  begin
    if local_path
      lib_path = File.join(local_path, "lib")
      $LOAD_PATH.unshift(lib_path) unless $LOAD_PATH.include?(lib_path)
    end

    begin
      require gem_name
    rescue LoadError
      require gem_name.tr("-", "_")
    end

    pascal = name.split(/[-_]/).map(&:capitalize).join
    mod = if defined?(Brainiac::Plugins) && Brainiac::Plugins.const_defined?(pascal)
            Brainiac::Plugins.const_get(pascal)
          else
            Brainiac::Plugins.constants.find { |c| c.to_s.downcase == name.downcase }&.then { |c| Brainiac::Plugins.const_get(c) }
          end

    return unless mod

    # If plugin reports it's not configured, run setup automatically
    if mod.respond_to?(:configured?) && !mod.configured? && mod.respond_to?(:cli)
      puts ""
      mod.cli(["setup"])
    end
  rescue LoadError
    # Plugin couldn't be loaded — skip setup (will be caught on first use)
    nil
  rescue StandardError => e
    puts "  Note: Auto-setup skipped (#{e.message})"
  end
end

# Collect help text from installed plugins for the help command.
def collect_plugin_help_lines
  plugins_file = File.join(BRAINIAC_DIR, "plugins.json")
  plugins_config = File.exist?(plugins_file) ? JSON.parse(File.read(plugins_file)) : { "plugins" => [] }

  (plugins_config["plugins"] || []).filter_map do |pentry|
    pname = pentry.is_a?(Hash) ? pentry["name"] : pentry.to_s
    load_plugin_help(pname, pentry)
  end
end

def load_plugin_help(pname, pentry)
  if pentry.is_a?(Hash) && pentry["path"]
    lib_path = File.join(pentry["path"], "lib")
    $LOAD_PATH.unshift(lib_path) unless $LOAD_PATH.include?(lib_path)
  end

  # Try to load just the metadata file (lightweight, no runtime deps)
  metadata_loaded = try_require_metadata(pname, pentry)

  # Fall back to loading the full plugin if metadata file doesn't exist
  unless metadata_loaded
    gem_name = "brainiac-#{pname}"
    begin
      require gem_name
    rescue LoadError
      require gem_name.tr("-", "_")
    end
  end

  mod = resolve_plugin_module_for(pname)
  if mod.respond_to?(:help_text)
    mod.help_text
  elsif mod.respond_to?(:cli)
    "    #{pname.ljust(28)} Run 'brainiac #{pname} help' for commands"
  end
rescue LoadError
  "    #{pname.ljust(28)} (could not load — reinstall with: brainiac install #{pname})"
rescue StandardError
  nil
end

def try_require_metadata(pname, pentry)
  if pentry.is_a?(Hash) && pentry["path"]
    metadata_file = File.join(pentry["path"], "lib", "brainiac", "plugins", pname, "metadata.rb")
    if File.exist?(metadata_file)
      load metadata_file
      return true
    end
  end

  # Try gem path via standard require
  begin
    require "brainiac/plugins/#{pname}/metadata"
    true
  rescue LoadError
    false
  end
end

# Load only the plugin's CLI module (metadata + cli) without the full server runtime.
# Returns true if successfully loaded, false if no CLI file exists.
def try_require_plugin_cli(pname, pentry)
  plugin_dir = (File.join(pentry["path"], "lib", "brainiac", "plugins", pname) if pentry.is_a?(Hash) && pentry["path"])

  # Load metadata first (defines module + help_text/configured?)
  try_require_metadata(pname, pentry)

  # Load CLI file
  if plugin_dir
    cli_file = File.join(plugin_dir, "cli.rb")
    if File.exist?(cli_file)
      load cli_file
      return true
    end
  end

  # Try gem path
  begin
    require "brainiac/plugins/#{pname}/cli"
    true
  rescue LoadError
    false
  end
end

def resolve_plugin_module_for(name)
  return nil unless defined?(Brainiac::Plugins)

  pascal = name.split(/[-_]/).map(&:capitalize).join
  if Brainiac::Plugins.const_defined?(pascal)
    Brainiac::Plugins.const_get(pascal)
  else
    match = Brainiac::Plugins.constants.find { |c| c.to_s.downcase == name.downcase }
    match ? Brainiac::Plugins.const_get(match) : nil
  end
end

# Generate the plugin development SKILL.md content for the scaffold.
# Uses single-quoted heredoc to avoid interpolation issues with example code.
def generate_plugin_skill_md(plugin_name, pascal_name)
  <<~SKILL.gsub("__PLUGIN_NAME__", plugin_name).gsub("__PASCAL_NAME__", pascal_name)
    ---
    name: brainiac-plugin-development
    description: |
      How to develop Brainiac plugins. Covers the plugin contract, file structure,
      hooks, CLI commands, and architecture constraints.
    triggers:
      - plugin contract
      - plugin development
      - register app
      - brainiac hooks
    ---

    # Brainiac Plugin Development

    This is a Brainiac plugin gem. Plugins extend Brainiac with new communication
    channels, integrations, or features without modifying core.

    ## Plugin Contract

    A valid Brainiac plugin MUST:

    1. **Gem named `brainiac-<name>`**
    2. **Entry file at `lib/brainiac_<name>.rb`** — loaded by RubyGems
    3. **Module at `Brainiac::Plugins::<Name>`** — PascalCase
    4. **Implement `.register(app)`** — receives Sinatra::Application at server startup

    Optional but recommended:

    | Method | File | Purpose |
    |--------|------|---------|
    | `.register(app)` | main module | **Required.** Define routes, hooks, threads |
    | `.configured?` | `metadata.rb` | Returns false → auto-runs setup on install |
    | `.help_text` | `metadata.rb` | One-liner for `brainiac help` |
    | `.cli(args)` | `cli.rb` | CLI subcommands via `brainiac <plugin> ...` |

    ## Critical Architecture: CLI vs Server Runtime

    Plugins are loaded in TWO contexts:

    1. **Server context** — full plugin via `.register(app)`. Has `LOG`, `AGENT_REGISTRY`, etc.
    2. **CLI context** — only `metadata.rb` + `cli.rb`. NO server runtime.

    Rules:
    - `metadata.rb` requires only `version.rb`
    - `cli.rb` uses only stdlib (`json`, `net/http`, `fileutils`)
    - Everything else loaded only by `.register(app)`

    ## Available Hooks

    Subscribe in `.register(app)` via `Brainiac.on(:event)`:

    | Hook | When |
    |------|------|
    | `:server_started` | All plugins loaded |
    | `:pre_dispatch` | Before agent CLI spawned |
    | `:agent_completed` | Agent session finished |
    | `:agent_crashed` | Agent process crashed |
    | `:build_brain_context` | Building prompt context |
    | `:pr_merged` | GitHub PR merged |
    | `:pr_review_received` | PR review submitted |
    | `:pr_synchronized` | PR updated |
    | `:production_deployed` | Deploy succeeded |
    | `:create_work_item` | Create card/issue/ticket |
    | `:detect_cli_provider` | Detect CLI provider |
    | `:detect_effort` | Detect effort level |

    ## Channel Prompts

    For communication channel plugins:

    ```ruby
    Brainiac.register_channel_prompt(:my_channel, PROMPT_TEXT, pre_post_check: CHECK_TEXT)
    ```

    ## Core Functions (Server Context)

    | Function | Purpose |
    |----------|---------|
    | `agent_display_name(key)` | Display name for agent |
    | `agent_env_for(name)` | Env vars hash for agent |
    | `AGENT_REGISTRY` | All agents |
    | `PROJECTS` | All projects |
    | `LOG` | Logger |
    | `BRAINIAC_DIR` | ~/.brainiac/ path |
    | `register_session(key, pid, **)` | Track active session |
    | `session_active?(key)` | Check if session running |
    | `build_brain_context(...)` | Build brain context |
    | `render_prompt(template, vars, ...)` | Compose full prompt |
    | `detect_model(config, text:)` | Detect model from tags |
    | `parse_inline_tags(text)` | Parse inline tags |
    | `reload_projects!` | Reload projects.json |
    | `brain_push(message:)` | Push brain to git |

    ## Testing

    ```bash
    rake test       # Minitest
    rake rubocop    # Linter
    rake            # Both
    ```

    ## Reference Implementations

    - `brainiac-discord` — Communication channel (gateway, messages, delivery, reactions)
    - `brainiac-fizzy` — Card management (webhooks, hooks, duplicate detection, planning)
  SKILL
end

def start_server(daemon: false)
  # Resolve the real path of the brainiac script (follows symlinks)
  receiver_path = File.join(BRAINIAC_ROOT, "receiver.rb")
  receiver_dir = BRAINIAC_ROOT

  unless File.exist?(receiver_path)
    puts "Error: receiver.rb not found at #{receiver_path}"
    exit 1
  end

  # Check if already running
  if find_server_pid
    puts "Error: Brainiac server is already running."
    puts "Run 'brainiac stop' or 'brainiac restart' to manage it."
    exit 1
  end

  if daemon
    # Daemon mode: start in background (like the old behavior)
    log_dir = File.join(receiver_dir, "tmp")
    FileUtils.mkdir_p(log_dir)
    log_file = File.join(log_dir, "brainiac-server.log")

    puts "Starting Brainiac server (daemon)..."

    pid = spawn("ruby", receiver_path,
                chdir: receiver_dir,
                out: log_file,
                err: %i[child out])
    Process.detach(pid)

    ensure_brainiac_dir
    File.write(PID_FILE, pid.to_s)
    File.write(File.join(BRAINIAC_DIR, "server.root"), receiver_dir)

    puts "✓ Server started in background (PID: #{pid})"
    puts "  Logs: tail -f #{log_file}"
    puts "  Stop: brainiac stop"
    puts "  Restart: brainiac restart"
  else
    # Foreground mode (default): run in the current process like `rails server`
    puts "Starting Brainiac server (pid: #{Process.pid})..."
    puts "  Stop: Ctrl+C"
    puts ""

    ensure_brainiac_dir
    File.write(PID_FILE, Process.pid.to_s)
    File.write(File.join(BRAINIAC_DIR, "server.root"), receiver_dir)

    begin
      Dir.chdir(receiver_dir) do
        exec("ruby", receiver_path)
      end
    rescue Interrupt
      puts "\nStopping server..."
    ensure
      FileUtils.rm_f(PID_FILE)
    end
  end
end

def detect_project_info(path)
  path = File.expand_path(path)

  # Get git remote URL to extract repo name
  github_repo = nil
  if Dir.exist?(File.join(path, ".git"))
    remote_url, _, status = Open3.capture3("git", "remote", "get-url", "origin", chdir: path)
    if status.success?
      # Parse GitHub repo from URL (supports both HTTPS and SSH)
      if remote_url =~ %r{github\.com[/:](.+?)\.git}
        github_repo = Regexp.last_match(1)
      elsif remote_url =~ %r{github\.com[/:](.+)}
        github_repo = Regexp.last_match(1).chomp
      end
    end
  end

  # Suggest project key from directory name
  project_key = File.basename(path).downcase.gsub(/[^a-z0-9-]/, "-")

  {
    "repo_path" => path,
    "github_repo" => github_repo,
    "project_key" => project_key
  }
end

def register_project(options)
  path = options[:path] || Dir.pwd
  info = detect_project_info(path)

  projects = load_projects

  # Interactive prompts
  puts "Registering project from: #{info["repo_path"]}"
  puts

  print "Project key [#{info["project_key"]}]: "
  project_key = $stdin.gets.chomp
  project_key = info["project_key"] if project_key.empty?

  if projects.key?(project_key) && !options[:force]
    puts "Error: Project '#{project_key}' already exists. Use --force to overwrite."
    exit 1
  end

  print "Tags (comma-separated) [#{project_key}]: "
  tags_input = $stdin.gets.chomp
  project_tags = tags_input.empty? ? [project_key] : tags_input.split(",").map(&:strip)

  print "GitHub repo [#{info["github_repo"]}]: "
  github_repo = $stdin.gets.chomp
  github_repo = info["github_repo"] if github_repo.empty?

  print "CLI provider [kiro]: "
  cli_provider = $stdin.gets.chomp
  cli_provider = "kiro" if cli_provider.empty?

  print "Default model [auto]: "
  agent_model = $stdin.gets.chomp
  agent_model = "auto" if agent_model.empty?

  agent_default = default_agent_name
  if agent_default
    print "Agent name [#{agent_default}]: "
    agent_name = $stdin.gets.chomp
    agent_name = agent_default if agent_name.empty?
  else
    print "Agent name: "
    agent_name = $stdin.gets.chomp
    if agent_name.empty?
      puts "Error: No default agent configured. Provide a name or run 'brainiac agent default <name>' first."
      exit 1
    end
  end

  # Build project config
  project_config = {
    "repo_path" => info["repo_path"],
    "tags" => project_tags,
    "github_repo" => github_repo,
    "agent_name" => agent_name,
    "agent_model" => agent_model,
    "cli_provider" => cli_provider
  }

  projects[project_key] = project_config
  save_projects(projects)

  puts
  puts "✓ Project '#{project_key}' registered successfully!"
  puts "  Repo: #{info["repo_path"]}"
  puts "  Tags: #{project_tags.join(", ")}"
  puts "  GitHub: #{github_repo}" if github_repo
end

def unregister_project(project_key)
  projects = load_projects

  unless projects.key?(project_key)
    puts "Error: Project '#{project_key}' not found."
    exit 1
  end

  projects.delete(project_key)
  save_projects(projects)

  puts "✓ Project '#{project_key}' unregistered."
end

def list_projects
  projects = load_projects

  if projects.empty?
    puts "No projects registered."
    puts "Run 'brainiac register' from a project directory to get started."
    return
  end

  puts "Registered projects:"
  puts

  projects.each do |key, config|
    default_marker = config["default"] ? " (default)" : ""
    puts "  #{key}#{default_marker}"
    puts "    Path: #{config["repo_path"]}"
    tags = config["tags"] || config["project_tags"]&.join(", ")
    puts "    Tags: #{tags}" if tags
    puts "    GitHub: #{config["github_repo"]}" if config["github_repo"]
    puts "    Agent: #{config["agent_cli"]} (model: #{config["agent_model"]})"
    puts
  end
end

def show_project(project_key)
  projects = load_projects

  unless projects.key?(project_key)
    puts "Error: Project '#{project_key}' not found."
    exit 1
  end

  config = projects[project_key]
  puts JSON.pretty_generate(config)
end

def configure_server(options)
  config = load_config

  config["server_url"] = options[:server_url] if options[:server_url]

  if options[:show]
    puts JSON.pretty_generate(config)
    return
  end

  # Interactive configuration
  current_url = config["server_url"] || "http://localhost:4567"
  print "Brainiac server URL [#{current_url}]: "
  server_url = $stdin.gets.chomp
  config["server_url"] = server_url.empty? ? current_url : server_url

  save_config(config)
  puts "✓ Configuration saved."
end

# --- Brain management ---

BRAIN_BASE_DIR   = File.join(BRAINIAC_DIR, "brain")
KNOWLEDGE_DIR    = File.join(BRAIN_BASE_DIR, "knowledge")
PERSONA_BASE_DIR = File.join(BRAIN_BASE_DIR, "persona")
MEMORY_BASE_DIR  = File.join(BRAIN_BASE_DIR, "memory")
KNOWLEDGE_COLLECTION = "brainiac-knowledge".freeze

def memory_dir_for(agent_name)
  File.join(MEMORY_BASE_DIR, agent_name.downcase.gsub(/[^a-z0-9-]/, "-"))
end

def persona_dir_for(agent_name)
  File.join(PERSONA_BASE_DIR, agent_name.downcase.gsub(/[^a-z0-9-]/, "-"))
end

def persona_collection_for(agent_name)
  "#{agent_name.downcase.gsub(/[^a-z0-9-]/, "-")}-persona"
end

def brain_init(agent_name)
  persona_dir = persona_dir_for(agent_name)
  persona_col = persona_collection_for(agent_name)

  FileUtils.mkdir_p(KNOWLEDGE_DIR)
  FileUtils.mkdir_p(persona_dir)
  FileUtils.mkdir_p(File.join(BRAIN_BASE_DIR, "memory"))

  # Check if qmd is available
  unless system("which qmd > /dev/null 2>&1")
    puts "✓ Brain directories created:"
    puts "  Knowledge: #{KNOWLEDGE_DIR}"
    puts "  Persona:   #{persona_dir}"
    puts ""
    puts "⚠  qmd is not installed. Install it to enable semantic search:"
    puts "   npm install -g @tobilu/qmd"
    puts ""
    puts "Then run: brainiac brain init #{agent_name}"
    return
  end

  # Set up shared knowledge collection (idempotent — qmd won't duplicate)
  puts "Setting up shared knowledge collection..."
  system("qmd", "collection", "add", KNOWLEDGE_DIR, "--name", KNOWLEDGE_COLLECTION)
  system("qmd", "context", "add", "qmd://#{KNOWLEDGE_COLLECTION}",
         "Shared technical knowledge: project conventions, coding patterns, architecture decisions, lessons learned")

  # Set up per-agent persona collection
  puts "Setting up persona collection for #{agent_name}..."
  system("qmd", "collection", "add", persona_dir, "--name", persona_col)
  system("qmd", "context", "add", "qmd://#{persona_col}",
         "Communication style and personality for AI agent #{agent_name}")

  # Set up card memory collection (per-agent)
  memory_dir = memory_dir_for(agent_name)
  FileUtils.mkdir_p(memory_dir)
  puts "Setting up card memory collection for #{agent_name}..."
  system("qmd", "collection", "add", memory_dir, "--name", "#{agent_name.downcase}-memory")
  system("qmd", "context", "add", "qmd://#{agent_name.downcase}-memory",
         "Per-card session memory for #{agent_name}: decisions, questions, answers, work status, timelines")

  puts "Indexing..."
  system("qmd", "update")

  puts ""
  puts "✓ Brain initialized for #{agent_name}"
  puts "  Knowledge (shared):  #{KNOWLEDGE_DIR}"
  puts "  Memory (#{agent_name}):  #{memory_dir}"
  puts "  Persona (#{agent_name}):  #{persona_dir}"
end

def brain_status(agent_name)
  persona_dir = persona_dir_for(agent_name)
  persona_col = persona_collection_for(agent_name)
  memory_dir = memory_dir_for(agent_name)

  knowledge_files = File.directory?(KNOWLEDGE_DIR) ? Dir.glob(File.join(KNOWLEDGE_DIR, "**", "*.md")) : []
  memory_files = File.directory?(memory_dir) ? Dir.glob(File.join(memory_dir, "**", "*.md")) : []
  persona_files = File.directory?(persona_dir) ? Dir.glob(File.join(persona_dir, "**", "*.md")) : []

  if knowledge_files.empty? && memory_files.empty? && persona_files.empty?
    puts "No brain found. Run 'brainiac brain init' to create one."
    return
  end

  puts "Knowledge (shared across all agents):"
  puts "  Directory:  #{KNOWLEDGE_DIR}"
  puts "  Collection: #{KNOWLEDGE_COLLECTION}"
  puts "  Files:      #{knowledge_files.size}"
  knowledge_files.each do |f|
    puts "    #{f.sub("#{KNOWLEDGE_DIR}/", "")} (#{File.size(f)} bytes)"
  end

  puts ""
  puts "Memory (#{agent_name}, per-card session history):"
  puts "  Directory:  #{memory_dir}"
  puts "  Collection: #{agent_name.downcase}-memory"
  puts "  Files:      #{memory_files.size}"
  memory_files.each do |f|
    puts "    #{f.sub("#{memory_dir}/", "")} (#{File.size(f)} bytes)"
  end

  puts ""
  puts "Persona (#{agent_name}):"
  puts "  Directory:  #{persona_dir}"
  puts "  Collection: #{persona_col}"
  puts "  Files:      #{persona_files.size}"
  persona_files.each do |f|
    puts "    #{f.sub("#{persona_dir}/", "")} (#{File.size(f)} bytes)"
  end
end

def brain_search(query, scope: :knowledge, agent_name: nil)
  unless system("which qmd > /dev/null 2>&1")
    puts "Error: qmd is not installed. Run: npm install -g @tobilu/qmd"
    exit 1
  end

  collection = case scope
               when :persona
                 agent_name ||= default_agent_name || "agent"
                 persona_collection_for(agent_name)
               else
                 KNOWLEDGE_COLLECTION
               end

  exec("qmd", "search", query, "-c", collection)
end

def brain_list
  puts "Knowledge (shared):"
  if File.directory?(KNOWLEDGE_DIR)
    files = Dir.glob(File.join(KNOWLEDGE_DIR, "**", "*.md"))
    puts "  #{KNOWLEDGE_DIR} (#{files.size} files)"
  else
    puts "  Not initialized"
  end

  puts ""
  puts "Memory (per-agent, per-card):"
  if File.directory?(MEMORY_BASE_DIR)
    agent_dirs = Dir.children(MEMORY_BASE_DIR).select { |d| File.directory?(File.join(MEMORY_BASE_DIR, d)) }
    if agent_dirs.empty?
      puts "  None"
    else
      agent_dirs.each do |d|
        agent_memory_dir = File.join(MEMORY_BASE_DIR, d)
        files = Dir.glob(File.join(agent_memory_dir, "**", "*.md"))
        puts "  #{d}: #{files.size} files"
      end
    end
  else
    puts "  Not initialized"
  end

  puts ""
  puts "Personas:"
  if File.directory?(PERSONA_BASE_DIR)
    dirs = Dir.children(PERSONA_BASE_DIR).select { |d| File.directory?(File.join(PERSONA_BASE_DIR, d)) }
    if dirs.empty?
      puts "  None"
    else
      dirs.each do |d|
        dir = File.join(PERSONA_BASE_DIR, d)
        files = Dir.glob(File.join(dir, "**", "*.md"))
        puts "  #{d} (#{files.size} files) — #{dir}"
      end
    end
  else
    puts "  Not initialized"
  end

  puts ""
  puts "Run 'brainiac brain init <agent-name>' to set up a new agent."
end

# Main CLI
options = {}
subcommand = ARGV.shift

case subcommand
when "setup"
  puts "🔧 Brainiac Setup"
  puts ""

  # Create directory structure
  dirs = %w[brain/knowledge brain/persona brain/memory handlers plans tmp/notify/draft tmp/notify/posted]
  dirs.each do |dir|
    path = File.join(BRAINIAC_DIR, dir)
    FileUtils.mkdir_p(path)
  end
  puts "✓ Created ~/.brainiac/ directory structure"

  # Copy example configs
  templates_dir = File.join(BRAINIAC_ROOT, "templates")
  if Dir.exist?(templates_dir)
    copied = 0
    Dir.glob(File.join(templates_dir, "*.example")).each do |template|
      dest = File.join(BRAINIAC_DIR, File.basename(template, ".example"))
      unless File.exist?(dest)
        FileUtils.cp(template, dest)
        copied += 1
      end
    end
    puts "✓ Copied #{copied} example config(s) to ~/.brainiac/ (existing files preserved)"
  end

  # Copy CLI provider examples
  providers_dir = File.join(BRAINIAC_DIR, "cli-providers")
  FileUtils.mkdir_p(providers_dir)
  providers_src = File.join(BRAINIAC_ROOT, "templates", "cli-providers")
  if Dir.exist?(providers_src)
    Dir.glob(File.join(providers_src, "*.example")).each do |template|
      dest = File.join(providers_dir, File.basename(template, ".example"))
      FileUtils.cp(template, dest) unless File.exist?(dest)
    end
  end

  # Agent setup — agents.json is the authority
  agents_file = File.join(BRAINIAC_DIR, "agents.json")
  existing_agents = if File.exist?(agents_file)
                      registry = JSON.parse(File.read(agents_file))
                      registry.keys
                    else
                      []
                    end

  puts ""
  if existing_agents.empty?
    puts "No agents found in ~/.brainiac/agents.json"
    print "Create your first agent? Name: "
    agent_name = $stdin.gets&.strip
    if agent_name && !agent_name.empty?
      agent_key = agent_name.downcase.gsub(/[^a-z0-9-]/, "-")
      registry = { agent_key => { "display_name" => agent_name, "local" => true, "env" => {} } }
      File.write(agents_file, JSON.pretty_generate(registry))
      puts "✓ Created #{agents_file} with agent '#{agent_name}'"
      existing_agents = [agent_key]
    else
      agent_name = nil
      puts "  Skipped — add agents to ~/.brainiac/agents.json later"
    end
  else
    puts "Found #{existing_agents.size} agent(s): #{existing_agents.join(", ")}"
  end

  # Default agent selection
  brainiac_config_path = File.join(BRAINIAC_DIR, "brainiac.json")
  puts ""
  if File.exist?(brainiac_config_path)
    current = begin
      JSON.parse(File.read(brainiac_config_path)).fetch("default_agent", nil)
    rescue StandardError
      nil
    end
    puts "✓ Config already exists at ~/.brainiac/brainiac.json (default_agent: #{current})"
  else
    default_agent = if existing_agents.size == 1
                      name = existing_agents.first
                      # Look up display name if available
                      display = begin
                        JSON.parse(File.read(agents_file)).dig(name, "display_name") || name.capitalize
                      rescue StandardError
                        name.capitalize
                      end
                      print "Set #{display} as default agent? [Y/n] "
                      answer = $stdin.gets&.strip&.downcase
                      answer == "n" ? nil : display
                    elsif existing_agents.size > 1
                      puts "Choose default agent:"
                      display_names = existing_agents.map do |key|
                        JSON.parse(File.read(agents_file)).dig(key, "display_name") || key.capitalize
                      rescue StandardError
                        key.capitalize
                      end
                      display_names.each_with_index { |a, i| puts "  #{i + 1}) #{a}" }
                      print "Enter number [1]: "
                      choice = $stdin.gets&.strip
                      idx = choice.to_i - 1
                      idx = 0 if idx.negative? || idx >= display_names.size
                      display_names[idx]
                    else
                      agent_name
                    end

    default_agent ||= existing_agents.first&.capitalize
    config = { "default_agent" => default_agent }
    File.write(brainiac_config_path, JSON.pretty_generate(config))
    puts "✓ Wrote config to ~/.brainiac/brainiac.json (default_agent: #{default_agent})"
  end

  puts ""
  puts "Next steps:"
  puts "  1. Register projects: cd ~/Code/myproject && brainiac register"
  puts "  2. Initialize brain: brainiac brain init"
  puts "  3. Install plugins: brainiac install discord / fizzy / github / zoho"
  puts "  4. Start server: brainiac server"

  # Shell completion setup
  puts ""
  completion_source = File.join(BRAINIAC_ROOT, "bin", "brainiac-completion.bash")
  completion_target = File.join(BRAINIAC_DIR, "brainiac-completion.bash")
  if File.exist?(completion_source)
    FileUtils.cp(completion_source, completion_target)

    # Detect shell rc file
    shell = ENV.fetch("SHELL", "/bin/bash")
    rc_file = case shell
              when /zsh/ then File.expand_path("~/.zshrc")
              when /fish/ then nil # fish uses different mechanism
              else File.expand_path("~/.bashrc")
              end

    source_line = "[[ -r \"#{completion_target}\" ]] && source \"#{completion_target}\""

    if rc_file && File.exist?(rc_file) && !File.read(rc_file).include?("brainiac-completion")
      print "Add shell completion to #{rc_file}? [Y/n] "
      answer = $stdin.gets&.strip&.downcase
      if answer == "n"
        puts "  To add manually:"
        puts "    #{source_line}"
      else
        File.open(rc_file, "a") { |f| f.puts("\n# Brainiac CLI completion\n#{source_line}") }
        puts "✓ Added completion to #{rc_file}"
      end
    elsif rc_file && !File.exist?(rc_file)
      puts "  Shell completion installed to: #{completion_target}"
      puts "  Add to your shell rc file:"
      puts "    #{source_line}"
    else
      puts "✓ Shell completion already configured"
    end
  end

when "register", "add"
  OptionParser.new do |opts|
    opts.banner = "Usage: brainiac register [options]"
    opts.on("-p", "--path PATH", "Project path (default: current directory)")
    opts.on("-f", "--force", "Overwrite existing project")
  end.parse!(into: options)

  register_project(options)

when "unregister", "remove", "rm"
  if ARGV.empty?
    puts "Usage: brainiac unregister <project-key>"
    exit 1
  end
  unregister_project(ARGV[0])

when "list", "ls"
  list_projects

when "projects"
  # Support "brainiac projects list" as an alias for "brainiac list"
  projects_cmd = ARGV.shift
  case projects_cmd
  when "list", "ls", nil
    list_projects
  when "show"
    if ARGV.empty?
      puts "Usage: brainiac projects show <project-key>"
      exit 1
    end
    show_project(ARGV[0])
  when "default"
    project_key = ARGV[0]
    unless project_key
      puts "Usage: brainiac projects default <project-key>"
      puts "  Sets the default project for project-specific setup (e.g., .env copying)"
      exit 1
    end

    projects = load_projects
    unless projects.key?(project_key)
      puts "Error: Project '#{project_key}' not found."
      puts "Available projects: #{projects.keys.join(", ")}"
      exit 1
    end

    # Remove default flag from all projects, then set it on the target
    projects.each_value { |config| config.delete("default") }
    projects[project_key]["default"] = true
    save_projects(projects)

    puts "✓ Set '#{project_key}' as the default project"
  else
    puts "Unknown projects command: #{projects_cmd}"
    puts "Available: list, show, default"
    exit 1
  end

when "show"
  if ARGV.empty?
    puts "Usage: brainiac show <project-key>"
    exit 1
  end
  show_project(ARGV[0])

when "config"
  OptionParser.new do |opts|
    opts.banner = "Usage: brainiac config [options]"
    opts.on("-s", "--server-url URL", "Brainiac server URL")
    opts.on("--show", "Show current configuration")
  end.parse!(into: options)

  configure_server(options)

when "server", "s"
  OptionParser.new do |opts|
    opts.banner = "Usage: brainiac server [options]"
    opts.on("-d", "--daemon", "Run server in background (detached)")
  end.parse!(into: options)

  start_server(daemon: options[:daemon])

when "stop"
  stop_server

when "restart"
  puts "Restarting Brainiac server..."
  wait_for_agents_to_finish if find_server_pid
  if stop_server
    # Wait a bit longer to ensure the process is fully dead
    sleep 2

    # Double-check that the process is really gone
    if find_server_pid
      puts "Warning: Old server process still running, forcing kill..."
      pid = find_server_pid
      begin
        Process.kill("KILL", pid)
        sleep 1
      rescue Errno::ESRCH
        # Already dead
      end
      FileUtils.rm_f(PID_FILE)
    end
  end

  start_server(daemon: true)

when "logs", "log"
  # Tail the server log
  log_file = File.join(BRAINIAC_ROOT, "tmp", "brainiac-server.log")

  unless File.exist?(log_file)
    puts "No log file found at #{log_file}"
    puts "Is the server running? Check with: brainiac status"
    exit 1
  end

  exec("tail", "-f", log_file)

when "status"
  pid = find_server_pid
  if pid
    puts "Brainiac server is running (PID: #{pid})"
  else
    puts "Brainiac server is not running"
  end

when "path"
  puts BRAINIAC_DIR

when "work-items", "card-map"
  work_items_file = File.join(BRAINIAC_DIR, "work_items.json")
  cm_cmd = ARGV.shift
  case cm_cmd
  when "clean"
    unless File.exist?(work_items_file)
      puts "No work items found."
      exit 0
    end
    map = JSON.parse(File.read(work_items_file))
    before = map.size
    # Remove entries with no valid worktree on disk
    map.reject! { |_id, info| info["worktree"].nil? || !File.directory?(info["worktree"].to_s) }
    after = map.size
    removed = before - after
    File.write(work_items_file, JSON.pretty_generate(map))
    puts "Cleaned work items: removed #{removed} stale entries (#{before} → #{after})"
  when "list", "ls", nil
    unless File.exist?(work_items_file)
      puts "No work items found."
      exit 0
    end
    map = JSON.parse(File.read(work_items_file))
    if map.empty?
      puts "No active work items."
    else
      map.each_value do |info|
        num = info["number"] ? "##{info["number"]}" : "(no number)"
        agent = info["agent"] || "(no agent)"
        worktree_exists = info["worktree"] && File.directory?(info["worktree"].to_s) ? "✓" : "✗"
        puts "#{num.ljust(8)} #{agent.ljust(18)} #{worktree_exists} #{info["worktree"] || "(none)"}"
      end
    end
  else
    puts "Usage: brainiac work-items [clean|list]"
    puts "  clean   Remove stale entries (missing worktrees)"
    puts "  list    Show all card map entries"
  end

when "brain"
  brain_cmd = ARGV.shift
  case brain_cmd
  when "init"
    agent = ARGV[0] || default_agent_name
    unless agent
      puts "Usage: brainiac brain init <agent-name>"
      puts "  Or set a default: brainiac agent default <name>"
      exit 1
    end
    brain_init(agent)
  when "status", "show"
    agent = ARGV[0] || default_agent_name
    unless agent
      puts "Usage: brainiac brain status <agent-name>"
      puts "  Or set a default: brainiac agent default <name>"
      exit 1
    end
    brain_status(agent)
  when "search", "query"
    scope = :knowledge
    agent_name = default_agent_name
    if ARGV.include?("--persona")
      ARGV.delete("--persona")
      scope = :persona
    end
    if ARGV.include?("--agent")
      idx = ARGV.index("--agent")
      agent_name = ARGV.delete_at(idx + 1)
      ARGV.delete_at(idx)
    end
    if ARGV.empty?
      puts "Usage: brainiac brain search [--persona] [--agent <name>] <query>"
      exit 1
    end
    brain_search(ARGV.join(" "), scope: scope, agent_name: agent_name)
  when "list", "ls"
    brain_list
  when "path"
    what = ARGV[0]
    if what == "persona"
      agent = ARGV[1] || default_agent_name
      unless agent
        puts "Usage: brainiac brain path persona <agent-name>"
        exit 1
      end
      puts persona_dir_for(agent)
    else
      puts KNOWLEDGE_DIR
    end
  else
    puts <<~HELP
      Usage: brainiac brain <command> [options]

      Commands:
        init [agent-name]                       Initialize brain (shared knowledge + agent persona)
        status [agent-name]                     Show brain status and files
        search [--persona] [--agent name] <q>   Search knowledge (default) or persona
        list                                    List knowledge and all personas
        path                                    Show knowledge directory
        path persona [agent-name]               Show persona directory

      The brain has two parts:
        knowledge/  — shared across all agents (project conventions, patterns, lessons)
        persona/    — per-agent (communication style, tone, personality)

      Knowledge is automatically queried when agents do work.
      Persona is only queried when agents write comments.

      Examples:
        brainiac brain init                    # Init for default agent
        brainiac brain init Nova               # Init persona for Nova
        brainiac brain search "ruby style"     # Search shared knowledge
        brainiac brain search --persona "tone" # Search persona
        brainiac brain list                    # List everything
    HELP
  end

when "cron"
  cron_cmd = ARGV.shift
  config = load_config
  server_url = config["server_url"] || "http://localhost:4567"

  case cron_cmd
  when "add", "create"
    # Parse arguments
    schedule = nil
    agent = default_agent_name
    project = nil
    model = nil
    effort = nil
    notify_channel = nil
    notify_target = nil
    forum_title = nil
    repeat_count = nil
    prompt = nil
    script = nil

    OptionParser.new do |opts|
      opts.banner = "Usage: brainiac cron add [options] \"<prompt or --script path>\""
      opts.on("-s", "--schedule EXPR", "Cron expression, @shorthand, or one-time schedule") { |v| schedule = v }
      opts.on("-a", "--agent NAME", "Agent name (default: $AI_AGENT_NAME)") { |v| agent = v }
      opts.on("-p", "--project KEY", "Project key") { |v| project = v }
      opts.on("-m", "--model MODEL", "Model to use (opus, sonnet, haiku, auto)") { |v| model = v }
      opts.on("-e", "--effort LEVEL", "Effort level (low, medium, high, xhigh, max)") { |v| effort = v }
      opts.on("-d", "--notify TARGET", "Notification target (channel ID, webhook URL, etc.)") { |v| notify_target = v }
      opts.on("-c", "--channel CHANNEL", "Notification channel name (provided by plugins)") { |v| notify_channel = v }
      opts.on("-t", "--title TITLE", "Forum post title (for forum channels)") { |v| forum_title = v }
      opts.on("-r", "--repeat COUNT", Integer, "Number of times to repeat (for recurring schedules)") { |v| repeat_count = v }
      opts.on("--script PATH", "Run script directly (no agent, output posted via notify)") { |v| script = v }
    end.parse!

    prompt = ARGV.join(" ") unless script

    unless schedule && project && (prompt&.length&.> 0 || script)
      puts "Error: Missing required arguments"
      puts ""
      puts "Usage examples:"
      puts "  # Agent with prompt (recurring)"
      puts "  brainiac cron add -s \"0 9 * * *\" -p marketplace \"Daily standup\""
      puts ""
      puts "  # Script mode (no agent, direct execution)"
      puts "  brainiac cron add -s \"0 9 * * *\" -p brainiac --script ~/.brainiac/scripts/report.sh -d 1234567890"
      puts ""
      puts "  # Recurring (shorthand)"
      puts "  brainiac cron add -s @daily -p brainiac \"Security audit\""
      puts ""
      puts "  # One-time (natural language)"
      puts "  brainiac cron add -s \"tomorrow at 9am\" -p marketplace \"Reminder\""
      puts "  brainiac cron add -s \"in 2 hours\" -p brainiac \"Follow up\""
      puts "  brainiac cron add -s \"next monday at 3pm\" -p marketplace \"Weekly review\""
      puts ""
      puts "  # Recurring with repeat limit"
      puts "  brainiac cron add -s \"0 9 * * *\" -r 7 -p marketplace \"Daily reminder for 7 days\""
      puts "  brainiac cron add -s @daily -r 3 -p brainiac \"Reminder for 3 days\""
      exit 1
    end

    # Generate ID from prompt or script
    id = (script ? File.basename(script, ".*") : prompt).downcase.gsub(/[^a-z0-9]+/, "-")[0..30]

    # Call server API
    uri = URI("#{server_url}/api/cron/add")
    req = Net::HTTP::Post.new(uri, "Content-Type" => "application/json")
    payload = { id: id, schedule: schedule, agent: agent, project: project }
    payload[:prompt] = prompt if prompt
    payload[:script] = script if script
    payload[:model] = model if model
    payload[:effort] = effort if effort
    payload[:notify_channel] = notify_channel if notify_channel
    payload[:notify_target] = notify_target if notify_target
    payload[:forum_title] = forum_title if forum_title
    payload[:repeat_count] = repeat_count if repeat_count
    req.body = payload.to_json

    begin
      response = Net::HTTP.start(uri.hostname, uri.port) { |http| http.request(req) }
      data = JSON.parse(response.body)
      if data["success"]
        puts "✓ Cron job added: #{id}"
        puts "  Schedule: #{schedule}"
        puts "  Agent: #{script ? "none (script mode)" : agent}"
        puts "  Project: #{project}"
        puts "  Model: #{model || "default"}" unless script
        puts "  Effort: #{effort || "default"}" unless script
        puts "  Notify: #{notify_target ? "#{notify_channel || "default"} → #{notify_target}" : "none"}"
        puts "  Forum title: #{forum_title || "auto"}" if notify_target && forum_title
        puts "  Repeat: #{repeat_count ? "#{repeat_count} times" : "unlimited"}"
        puts script ? "  Script: #{script}" : "  Prompt: #{prompt}"
      else
        puts "Error: #{data["error"]}"
        exit 1
      end
    rescue StandardError => e
      puts "Could not reach server: #{e.message}"
      puts "Is the server running? Check with: brainiac status"
      exit 1
    end

  when "list", "ls"
    begin
      uri = URI("#{server_url}/api/cron")
      response = Net::HTTP.get_response(uri)
      data = JSON.parse(response.body)

      if data["jobs"].empty?
        puts "No cron jobs configured."
        puts "Add one with: brainiac cron add -s \"0 9 * * *\" -p marketplace \"Daily summary\""
        puts "Or one-time: brainiac cron add -s \"tomorrow at 9am\" -p marketplace \"Reminder\""
      else
        puts "Cron jobs:"
        data["jobs"].each do |id, job|
          status = job["enabled"] ? "✓" : "✗"
          last_run = job["last_run"] ? Time.parse(job["last_run"]).strftime("%Y-%m-%d %H:%M") : "never"
          execution_count = job["execution_count"] || 0

          # Show one-time jobs differently
          schedule_display = job["schedule"]
          if job["parsed"] && job["parsed"]["one_time"]
            target_time = Time.parse(job["parsed"]["timestamp"])
            schedule_display = "#{job["schedule"]} (#{target_time.strftime("%Y-%m-%d %H:%M")})"
            schedule_display += " [COMPLETED]" unless job["enabled"]
          elsif job["repeat_count"]
            schedule_display = "#{job["schedule"]} (#{execution_count}/#{job["repeat_count"]} runs)"
            schedule_display += " [COMPLETED]" unless job["enabled"]
          end

          puts "  #{status} #{id}"
          puts "    Schedule: #{schedule_display}"
          puts "    Agent: #{job["script"] ? "none (script mode)" : job["agent"]} | Project: #{job["project"]}"
          notify_ch = job["notify_channel"]
          notify_tgt = job["notify_target"]
          puts "    Notify: #{notify_ch || "default"} → #{notify_tgt}" if notify_tgt
          puts job["script"] ? "    Script: #{job["script"]}" : "    Prompt: #{job["prompt"]}"
          puts "    Last run: #{last_run}"
          puts
        end
      end
    rescue StandardError => e
      puts "Could not reach server: #{e.message}"
      exit 1
    end

  when "remove", "rm", "delete"
    id = ARGV[0]
    unless id
      puts "Usage: brainiac cron remove <job-id>"
      exit 1
    end

    uri = URI("#{server_url}/api/cron/remove")
    req = Net::HTTP::Post.new(uri, "Content-Type" => "application/json")
    req.body = { id: id }.to_json

    begin
      response = Net::HTTP.start(uri.hostname, uri.port) { |http| http.request(req) }
      data = JSON.parse(response.body)
      if data["success"]
        puts "✓ Removed cron job: #{id}"
      else
        puts "Error: #{data["error"]}"
        exit 1
      end
    rescue StandardError => e
      puts "Could not reach server: #{e.message}"
      exit 1
    end

  when "enable"
    id = ARGV[0]
    unless id
      puts "Usage: brainiac cron enable <job-id>"
      exit 1
    end

    uri = URI("#{server_url}/api/cron/toggle")
    req = Net::HTTP::Post.new(uri, "Content-Type" => "application/json")
    req.body = { id: id, enabled: true }.to_json

    begin
      response = Net::HTTP.start(uri.hostname, uri.port) { |http| http.request(req) }
      data = JSON.parse(response.body)
      if data["success"]
        puts "✓ Enabled cron job: #{id}"
      else
        puts "Error: #{data["error"]}"
        exit 1
      end
    rescue StandardError => e
      puts "Could not reach server: #{e.message}"
      exit 1
    end

  when "disable"
    id = ARGV[0]
    unless id
      puts "Usage: brainiac cron disable <job-id>"
      exit 1
    end

    uri = URI("#{server_url}/api/cron/toggle")
    req = Net::HTTP::Post.new(uri, "Content-Type" => "application/json")
    req.body = { id: id, enabled: false }.to_json

    begin
      response = Net::HTTP.start(uri.hostname, uri.port) { |http| http.request(req) }
      data = JSON.parse(response.body)
      if data["success"]
        puts "✓ Disabled cron job: #{id}"
      else
        puts "Error: #{data["error"]}"
        exit 1
      end
    rescue StandardError => e
      puts "Could not reach server: #{e.message}"
      exit 1
    end

  when "update"
    id = ARGV[0]
    schedule = nil
    notify_target = nil
    notify_channel = nil
    forum_title = nil

    OptionParser.new do |opts|
      opts.banner = "Usage: brainiac cron update <job-id> [options]"
      opts.on("-s", "--schedule EXPR", "New cron expression") { |v| schedule = v }
      opts.on("-d", "--notify TARGET", "New notification target") { |v| notify_target = v }
      opts.on("-c", "--channel CHANNEL", "New notification channel") { |v| notify_channel = v }
      opts.on("-t", "--title TITLE", "New forum post title") { |v| forum_title = v }
    end.parse!

    unless id && (schedule || notify_target || notify_channel || forum_title)
      puts "Error: Missing required arguments"
      puts "Usage: brainiac cron update <job-id> -s \"42 13 * * 1-5\""
      puts "   or: brainiac cron update <job-id> -d \"channel-id\" -c channel-name"
      puts "   or: brainiac cron update <job-id> -t \"Daily Update\""
      exit 1
    end

    uri = URI("#{server_url}/api/cron/update")
    req = Net::HTTP::Post.new(uri, "Content-Type" => "application/json")
    payload = { id: id }
    payload[:schedule] = schedule if schedule
    payload[:notify_channel] = notify_channel if notify_channel
    payload[:notify_target] = notify_target if notify_target
    payload[:forum_title] = forum_title if forum_title
    req.body = payload.to_json

    begin
      response = Net::HTTP.start(uri.hostname, uri.port) { |http| http.request(req) }
      data = JSON.parse(response.body)
      if data["success"]
        puts "✓ Updated cron job: #{id}"
        puts "  New schedule: #{schedule}" if schedule
        puts "  New notify: #{notify_channel || "default"} → #{notify_target}" if notify_target
        puts "  New forum title: #{forum_title}" if forum_title
      else
        puts "Error: #{data["error"]}"
        exit 1
      end
    rescue StandardError => e
      puts "Could not reach server: #{e.message}"
      exit 1
    end

  else
    puts <<~HELP
      Usage: brainiac cron <command>

      Commands:
        add -s <schedule> -p <project> [-a <agent>] "<prompt>"
                                        Add a new cron job
        list                            List all cron jobs
        remove <job-id>                 Remove a cron job
        enable <job-id>                 Enable a cron job
        disable <job-id>                Disable a cron job
        update <job-id> [-s <schedule>] [-c <channel>]
                                        Update a cron job's schedule and/or Discord channel

      Schedule format:
        Cron expression: "minute hour day month weekday"
          Examples:
            "0 9 * * 1-5"  — 9am on weekdays
            "0 */4 * * *"  — Every 4 hours
            "30 17 * * *"  — 5:30pm daily

        Special strings:
          @hourly   — Every hour (minute 0)
          @daily    — Every day at midnight
          @weekly   — Every Sunday at midnight
          @monthly  — First day of month at midnight

        One-time (natural language):
          "tomorrow at 9am"
          "in 2 hours"
          "next monday at 3pm"
      #{"    "}
        One-time (ISO8601):
          "2026-02-27T09:00:00-05:00"

      Examples:
        # Recurring
        brainiac cron add -s "0 9 * * *" -p marketplace "Summarize yesterday's work"
        brainiac cron add -s "@daily" -p brainiac -a Robin "Run security audit"
      #{"  "}
        # One-time
        brainiac cron add -s "tomorrow at 9am" -p marketplace "Reminder about priorities"
        brainiac cron add -s "in 30 minutes" -p brainiac "Follow up on PR"
      #{"  "}
        # Management
        brainiac cron list
        brainiac cron update post-morning-message -s "42 13 * * 1-5"
        brainiac cron disable daily-summary
        brainiac cron remove daily-summary

      Config file: #{BRAINIAC_DIR}/cron.json
    HELP
  end

when "provider"
  provider_cmd = ARGV.shift
  providers_dir = File.join(BRAINIAC_DIR, "cli-providers")

  case provider_cmd
  when "list", "ls"
    unless Dir.exist?(providers_dir)
      puts "No providers configured. Run 'brainiac provider add <name>' to create one."
      exit 0
    end
    files = Dir.glob(File.join(providers_dir, "*.json"))
    if files.empty?
      puts "No providers configured."
    else
      files.each do |f|
        name = File.basename(f, ".json")
        data = JSON.parse(File.read(f))
        puts "#{name} — #{data["binary"]} (#{data["models"]&.size || 0} models)"
      end
    end

  when "show"
    name = ARGV[0]
    unless name
      puts "Usage: brainiac provider show <name>"
      exit 1
    end
    file = File.join(providers_dir, "#{name}.json")
    unless File.exist?(file)
      puts "Provider '#{name}' not found."
      exit 1
    end
    puts JSON.pretty_generate(JSON.parse(File.read(file)))

  when "add", "create"
    name = ARGV[0]
    unless name
      puts "Usage: brainiac provider add <name>"
      exit 1
    end
    FileUtils.mkdir_p(providers_dir)
    file = File.join(providers_dir, "#{name}.json")
    if File.exist?(file)
      puts "Provider '#{name}' already exists. Edit #{file} directly."
      exit 1
    end
    scaffold = {
      "binary" => name,
      "default_args" => "",
      "model_flag" => "--model",
      "list_models_command" => "",
      "models" => {}
    }
    File.write(file, JSON.pretty_generate(scaffold))
    puts "Created #{file} — edit it to configure the provider."

  else
    puts <<~HELP
      Usage: brainiac provider <command>

      Commands:
        list                 List configured CLI providers
        show <name>          Show provider configuration
        add <name>           Create a new provider config
    HELP
  end

when "agent"
  agent_cmd = ARGV.shift
  agent_registry_file = File.join(BRAINIAC_DIR, "agents.json")

  case agent_cmd
  when "list", "ls"
    registry = File.exist?(agent_registry_file) ? JSON.parse(File.read(agent_registry_file)) : {}

    # Determine current default agent
    default_agent = default_agent_name

    if registry.empty?
      puts "No agents in registry."
    else
      agents = registry.select { |_, e| e.is_a?(Hash) }.map do |key, entry|
        display = entry["display_name"] || key.capitalize
        details = []
        if entry["role"]
          roles = Array(entry["role"])
          details << roles.join(", ")
        end
        details << "cli:#{entry["cli_provider"]}" if entry["cli_provider"]
        details << "env:#{entry["env"].size}" if entry["env"]&.any?
        is_default = default_agent && display.downcase == default_agent.downcase
        { key: key, display: display, local: entry["local"], details: details.join(" | "), default: is_default }
      end

      local, remote = agents.partition { |a| a[:local] }

      local.each do |a|
        line = "  #{a[:display]} (#{a[:key]})"
        line += "  ★ default" if a[:default]
        line += "  #{a[:details]}" unless a[:details].empty?
        puts line
      end

      unless remote.empty?
        puts "" if local.any?
        puts "  Remote:" if local.any?
        remote.each do |a|
          line = "  #{a[:display]} (#{a[:key]})"
          line += "  ★ default" if a[:default]
          line += "  #{a[:details]}" unless a[:details].empty?
          puts line
        end
      end
    end

  when "default"
    brainiac_config_path = File.join(BRAINIAC_DIR, "brainiac.json")
    brainiac_config = File.exist?(brainiac_config_path) ? JSON.parse(File.read(brainiac_config_path)) : {}
    name = ARGV.shift

    if name
      # Set default agent
      registry = File.exist?(agent_registry_file) ? JSON.parse(File.read(agent_registry_file)) : {}
      agent_key = name.downcase.gsub(/[^a-z0-9-]/, "-")

      # Resolve display name from registry if it exists
      display_name = if registry.dig(agent_key, "display_name")
                       registry[agent_key]["display_name"]
                     else
                       name
                     end

      brainiac_config["default_agent"] = display_name
      ensure_brainiac_dir
      File.write(brainiac_config_path, JSON.pretty_generate(brainiac_config))
      puts "✓ Default agent set to '#{display_name}'"
    else
      # Show current default
      env_override = ENV.fetch("AI_AGENT_NAME", nil)
      config_default = brainiac_config["default_agent"]

      if env_override
        puts "Default agent: #{env_override} (from AI_AGENT_NAME env var)"
        puts "  Config value: #{config_default}" if config_default && config_default != env_override
      elsif config_default
        puts "Default agent: #{config_default}"
      else
        puts "No default agent configured."
        puts "Set one with: brainiac agent default <name>"
        puts "  Or set AI_AGENT_NAME in your environment."
      end
    end

  when "create", "add"
    name = ARGV.shift
    unless name
      puts "Usage: brainiac agent create <name> [options]"
      puts ""
      puts "Options:"
      puts "  --local              Mark agent as local (dispatches on this machine)"
      puts "  --role <role>        Assign a role (repeatable)"
      puts "  --cli <provider>     Set CLI provider (default: kiro)"
      puts "  --persona <text>     Create a persona style file with this description"
      puts ""
      puts "If no options are given and stdin is a terminal, interactive mode is used."
      puts ""
      puts "Examples:"
      puts "  brainiac agent create MyAgent   # interactive"
      puts "  brainiac agent create SecurityBot --local --role code-reviewer"
      puts "  brainiac agent create Jane --role general-engineer --cli grok"
      puts "  brainiac agent create Merlin --persona \"Wise, enigmatic, helpful\""
      exit 1
    end

    agent_key = name.downcase.gsub(/[^a-z0-9-]/, "-")
    registry = File.exist?(agent_registry_file) ? JSON.parse(File.read(agent_registry_file)) : {}

    if registry[agent_key]
      puts "Agent '#{name}' already exists. Use 'brainiac agent #{agent_key} show' to view."
      exit 1
    end

    local = false
    roles = []
    cli_provider = nil
    persona_text = nil

    if ARGV.any?
      # Flag mode
      while ARGV.any?
        case ARGV[0]
        when "--local"
          ARGV.shift
          local = true
        when "--role"
          ARGV.shift
          roles << ARGV.shift
        when "--cli"
          ARGV.shift
          cli_provider = ARGV.shift
        when "--persona"
          ARGV.shift
          persona_text = ARGV.shift
        else
          puts "Unknown option: #{ARGV[0]}"
          exit 1
        end
      end
    elsif $stdin.tty?
      # Interactive mode
      puts "Creating agent '#{name}' (#{agent_key})"
      puts ""

      print "Local (dispatches on this machine)? [y/N]: "
      local = $stdin.gets.chomp.downcase.start_with?("y")

      # Show available CLI providers
      providers_dir = File.join(BRAINIAC_DIR, "cli-providers")
      available_providers = Dir.exist?(providers_dir) ? Dir.glob(File.join(providers_dir, "*.json")).map { |f| File.basename(f, ".json") } : []
      hint = available_providers.any? ? " (#{available_providers.join(", ")})" : ""
      print "CLI provider#{hint} [kiro]: "
      input = $stdin.gets.chomp
      cli_provider = input.empty? ? nil : input

      # Show available roles
      roles_dir = File.join(BRAINIAC_DIR, "roles")
      available_roles = Dir.exist?(roles_dir) ? Dir.glob(File.join(roles_dir, "*.md")).map { |f| File.basename(f, ".md") } : []
      hint = available_roles.any? ? " (#{available_roles.join(", ")})" : ""
      print "Roles#{hint} (comma-separated) []: "
      input = $stdin.gets.chomp
      roles = input.empty? ? [] : input.split(",").map(&:strip)

      print "Persona description (tone/style, or blank to skip) []: "
      input = $stdin.gets.chomp
      persona_text = input.empty? ? nil : input
    end

    entry = { "display_name" => name }
    entry["local"] = true if local
    entry["cli_provider"] = cli_provider if cli_provider
    entry["role"] = roles.size == 1 ? roles.first : roles if roles.any?

    registry[agent_key] = entry
    File.write(agent_registry_file, JSON.pretty_generate(registry))
    puts "✓ Created agent '#{name}' (#{agent_key})"
    puts "  Local: #{local}" if local
    puts "  Role: #{roles.join(", ")}" if roles.any?
    puts "  CLI: #{cli_provider}" if cli_provider

    # Create persona directory and style file if requested
    if persona_text
      persona_dir = File.join(BRAINIAC_DIR, "brain", "persona", agent_key)
      FileUtils.mkdir_p(persona_dir)
      persona_file = File.join(persona_dir, "style.md")
      unless File.exist?(persona_file)
        File.write(persona_file, <<~MD)
          ---
          name: #{agent_key}-style
          description: Persona voice for #{name}.
          ---
          # #{name} — Persona
          #{persona_text}
        MD
        puts "  Persona: #{persona_file}"
      end
    end

    # Initialize brain (qmd collections) for local agents
    if local
      puts ""
      brain_init(name)
    end

    # Notify running server to reload and trigger :agent_added hook
    notify_server_reload

  when "remove", "delete", "rm"
    name = ARGV.shift
    unless name
      puts "Usage: brainiac agent remove <name>"
      exit 1
    end

    agent_key = name.downcase.gsub(/[^a-z0-9-]/, "-")
    registry = File.exist?(agent_registry_file) ? JSON.parse(File.read(agent_registry_file)) : {}

    unless registry[agent_key]
      puts "Agent '#{name}' not found in registry."
      exit 1
    end

    display = registry[agent_key]["display_name"] || name
    registry.delete(agent_key)
    File.write(agent_registry_file, JSON.pretty_generate(registry))
    puts "✓ Removed agent '#{display}' (#{agent_key}) from registry"
    puts "  Note: Persona files at ~/.brainiac/brain/persona/#{agent_key}/ were not deleted."

    # Notify running server to reload and trigger :agent_removed hook
    notify_server_reload

  when nil
    puts <<~HELP
      Usage: brainiac agent <name> <command> [args]
             brainiac agent list
             brainiac agent default [name]
             brainiac agent create <name> [options]
             brainiac agent remove <name>

      Commands:
        list                              List all agents in the registry
        default [name]                    Show or set the default agent
        create <name> [options]           Add a new agent to the registry
        remove <name>                     Remove an agent from the registry
        <name> show                       Show agent configuration (tokens redacted)
        <name> set <field> <value>        Update a config field (local, cli, role, persona, display_name)
        <name> env <KEY> <VALUE>          Set an env var for an agent
        <name> env                        List env vars for an agent
        <name> env --delete <KEY>         Remove an env var from an agent

      Create options (or interactive if no flags given):
        --local              Mark agent as local (dispatches on this machine)
        --role <role>        Assign a role (repeatable)
        --cli <provider>     Set CLI provider (default: kiro)
        --persona <text>     Create a persona style file

      Examples:
        brainiac agent list
        brainiac agent default Sherlock
        brainiac agent create SecurityBot --local --role code-reviewer
        brainiac agent create Jane --cli grok
        brainiac agent create MyAgent             # interactive mode
        brainiac agent remove SecurityBot
        brainiac agent sherlock set local true
        brainiac agent sherlock set persona "Dry, sardonic"
        brainiac agent sherlock set role code-reviewer,general-engineer
        brainiac agent sherlock env MY_TOKEN abc123
        brainiac agent sherlock show
    HELP

  else
    # Pattern: brainiac agent <name> <subcommand> [args]
    agent_key = agent_cmd.downcase.gsub(/[^a-z0-9-]/, "-")
    sub = ARGV.shift

    case sub
    when "show", nil
      registry = File.exist?(agent_registry_file) ? JSON.parse(File.read(agent_registry_file)) : {}
      entry = registry[agent_key]
      unless entry
        puts "Agent '#{agent_cmd}' not found in registry."
        exit 1
      end
      # Redact tokens in output
      display = entry.dup
      if display["env"]
        display["env"] = display["env"].transform_values { |v| v.length > 10 ? "#{v[0..6]}...#{v[-4..]}" : v }
      end
      puts JSON.pretty_generate(display)

    when "env"
      if ["--delete", "unset", "delete", "rm"].include?(ARGV[0])
        ARGV.shift
        var_name = ARGV.shift
        unless var_name
          puts "Usage: brainiac agent #{agent_cmd} env unset <KEY>"
          exit 1
        end
        registry = File.exist?(agent_registry_file) ? JSON.parse(File.read(agent_registry_file)) : {}
        unless registry.dig(agent_key, "env", var_name)
          puts "#{var_name} not set for '#{agent_cmd}'."
          exit 1
        end
        registry[agent_key]["env"].delete(var_name)
        registry[agent_key].delete("env") if registry[agent_key]["env"].empty?
        File.write(agent_registry_file, JSON.pretty_generate(registry))
        puts "✓ Removed #{var_name} from #{agent_cmd}"

      elsif ARGV.empty?
        # List env vars
        registry = File.exist?(agent_registry_file) ? JSON.parse(File.read(agent_registry_file)) : {}
        entry = registry[agent_key]
        unless entry.is_a?(Hash) && entry["env"]&.any?
          puts "No env vars configured for '#{agent_cmd}'."
          exit 0
        end
        entry["env"].each do |k, v|
          preview = v.length > 20 ? "#{v[0..16]}..." : v
          puts "  #{k}=#{preview}"
        end

      else
        var_name = ARGV.shift
        var_value = ARGV.shift
        unless var_name && var_value
          puts "Usage: brainiac agent #{agent_cmd} env <KEY> <VALUE>"
          exit 1
        end
        registry = File.exist?(agent_registry_file) ? JSON.parse(File.read(agent_registry_file)) : {}
        registry[agent_key] ||= {}
        registry[agent_key]["env"] ||= {}
        registry[agent_key]["env"][var_name] = var_value
        File.write(agent_registry_file, JSON.pretty_generate(registry))
        puts "✓ Set #{var_name} for #{agent_cmd}"
      end

    when "set"
      field = ARGV.shift
      value = ARGV.shift
      unless field
        puts "Usage: brainiac agent #{agent_cmd} set <field> <value>"
        puts ""
        puts "Fields:"
        puts "  local <true|false>     Set local dispatch flag"
        puts "  cli <provider>         Set CLI provider"
        puts "  role <roles>           Set roles (comma-separated, or 'none' to clear)"
        puts "  persona <text>         Set/update persona style file"
        puts "  display_name <name>    Set display name for @mentions"
        exit 1
      end

      registry = File.exist?(agent_registry_file) ? JSON.parse(File.read(agent_registry_file)) : {}
      unless registry[agent_key]
        puts "Agent '#{agent_cmd}' not found in registry."
        exit 1
      end

      case field
      when "local"
        if value == "true"
          registry[agent_key]["local"] = true
        else
          registry[agent_key].delete("local")
        end
        File.write(agent_registry_file, JSON.pretty_generate(registry))
        puts "✓ Set local=#{value} for #{agent_cmd}"

      when "cli"
        unless value
          puts "Usage: brainiac agent #{agent_cmd} set cli <provider>"
          exit 1
        end
        registry[agent_key]["cli_provider"] = value
        File.write(agent_registry_file, JSON.pretty_generate(registry))
        puts "✓ Set cli_provider=#{value} for #{agent_cmd}"

      when "role"
        unless value
          puts "Usage: brainiac agent #{agent_cmd} set role <roles|none>"
          exit 1
        end
        roles = value == "none" ? [] : value.split(",").map(&:strip)
        resolved_role = roles.one? ? roles.first : roles
        roles.empty? ? registry[agent_key].delete("role") : registry[agent_key]["role"] = resolved_role
        File.write(agent_registry_file, JSON.pretty_generate(registry))
        puts "✓ Set role for #{agent_cmd}"

      when "persona"
        unless value
          puts "Usage: brainiac agent #{agent_cmd} set persona <text>"
          exit 1
        end
        persona_dir = File.join(BRAINIAC_DIR, "brain", "persona", agent_key)
        FileUtils.mkdir_p(persona_dir)
        persona_file = File.join(persona_dir, "style.md")
        display = registry[agent_key]["display_name"] || agent_cmd.capitalize
        File.write(persona_file, <<~MD)
          ---
          name: #{agent_key}-style
          description: Persona voice for #{display}.
          ---
          # #{display} — Persona
          #{value}
        MD
        puts "✓ Wrote persona to #{persona_file}"

      when "display_name"
        unless value
          puts "Usage: brainiac agent #{agent_cmd} set display_name <name>"
          exit 1
        end
        registry[agent_key]["display_name"] = value
        File.write(agent_registry_file, JSON.pretty_generate(registry))
        puts "✓ Set display_name=#{value} for #{agent_cmd}"

      else
        puts "Unknown field '#{field}'. Available: local, cli, role, persona, display_name"
        exit 1
      end

    else
      puts "Unknown subcommand '#{sub}' for agent '#{agent_cmd}'."
      puts "Available: show, env, set"
      exit 1
    end
  end

when "role"
  role_cmd = ARGV.shift
  roles_dir = File.join(BRAINIAC_DIR, "roles")

  case role_cmd
  when "list", "ls"
    unless Dir.exist?(roles_dir)
      puts "No roles configured. Create markdown files in #{roles_dir}/"
      exit 0
    end
    files = Dir.glob(File.join(roles_dir, "*.md"))
    if files.empty?
      puts "No roles configured. Create markdown files in #{roles_dir}/"
    else
      # Show which agents use each role
      registry_file = File.join(BRAINIAC_DIR, "agents.json")
      registry = File.exist?(registry_file) ? JSON.parse(File.read(registry_file)) : {}
      agent_roles = {}
      registry.each do |key, entry|
        next unless entry.is_a?(Hash) && entry["role"]

        roles = entry["role"].is_a?(Array) ? entry["role"] : [entry["role"]]
        roles.each do |r|
          agent_roles[r] ||= []
          agent_roles[r] << (entry["display_name"] || key.capitalize)
        end
      end

      files.each do |f|
        name = File.basename(f, ".md")
        # Read first non-empty, non-heading line as description
        desc = File.readlines(f).find { |l| !l.strip.empty? && !l.start_with?("#") && !l.start_with?("---") }&.strip || ""
        agents = agent_roles[name]
        agent_str = agents ? " (#{agents.join(", ")})" : ""
        puts "#{name}#{agent_str} — #{desc[0..70]}"
      end
    end

  when "show"
    name = ARGV[0]
    unless name
      puts "Usage: brainiac role show <name>"
      exit 1
    end
    file = File.join(roles_dir, "#{name}.md")
    unless File.exist?(file)
      puts "Role '#{name}' not found. Available: #{Dir.glob(File.join(roles_dir, "*.md")).map { |f| File.basename(f, ".md") }.join(", ")}"
      exit 1
    end
    puts File.read(file)

  when "assign"
    agent_name = ARGV[0]
    role_name = ARGV[1]
    unless agent_name && role_name
      puts "Usage: brainiac role assign <agent> <role>"
      exit 1
    end

    file = File.join(roles_dir, "#{role_name}.md")
    unless File.exist?(file)
      puts "Role '#{role_name}' not found."
      exit 1
    end

    registry_file = File.join(BRAINIAC_DIR, "agents.json")
    registry = File.exist?(registry_file) ? JSON.parse(File.read(registry_file)) : {}
    key = agent_name.downcase.gsub(/[^a-z0-9-]/, "-")
    registry[key] ||= {}

    # Normalize existing role field to array
    existing = registry[key]["role"]
    roles = case existing
            when Array then existing
            when String then [existing]
            else []
            end

    if roles.include?(role_name)
      puts "#{agent_name} already has role '#{role_name}'"
    else
      roles << role_name
      registry[key]["role"] = roles.size == 1 ? roles.first : roles
      File.write(registry_file, JSON.pretty_generate(registry))
      puts "✓ Assigned role '#{role_name}' to #{agent_name}"
    end

  when "unassign", "remove-from"
    agent_name = ARGV[0]
    role_name = ARGV[1]
    unless agent_name && role_name
      puts "Usage: brainiac role unassign <agent> <role>"
      exit 1
    end

    registry_file = File.join(BRAINIAC_DIR, "agents.json")
    registry = File.exist?(registry_file) ? JSON.parse(File.read(registry_file)) : {}
    key = agent_name.downcase.gsub(/[^a-z0-9-]/, "-")

    unless registry[key]
      puts "Agent '#{agent_name}' not found in registry."
      exit 1
    end

    existing = registry[key]["role"]
    roles = case existing
            when Array then existing
            when String then [existing]
            else []
            end

    unless roles.include?(role_name)
      puts "#{agent_name} doesn't have role '#{role_name}'"
      exit 1
    end

    roles.delete(role_name)
    if roles.empty?
      registry[key].delete("role")
    elsif roles.size == 1
      registry[key]["role"] = roles.first
    else
      registry[key]["role"] = roles
    end
    File.write(registry_file, JSON.pretty_generate(registry))
    puts "✓ Removed role '#{role_name}' from #{agent_name}"

  when "create", "add"
    name = ARGV[0]
    unless name
      puts "Usage: brainiac role create <name>"
      exit 1
    end
    FileUtils.mkdir_p(roles_dir)
    file = File.join(roles_dir, "#{name}.md")
    if File.exist?(file)
      puts "Role '#{name}' already exists. Edit #{file} directly."
      exit 1
    end
    File.write(file, "# Role: #{name.split("-").map(&:capitalize).join(" ")}\n\nDescribe this role's responsibilities here.\n")
    puts "Created #{file} — edit it to define the role."

  else
    puts <<~HELP
      Usage: brainiac role <command>

      Commands:
        list                   List configured roles
        show <name>            Show role definition
        create <name>          Create a new role file
        assign <agent> <role>    Assign a role to an agent (additive)
        unassign <agent> <role>  Remove a role from an agent
    HELP
  end

when "completions"
  completion_file = File.join(__dir__, "brainiac-completion.bash")
  if ARGV[0] == "--install"
    target = File.expand_path("~/.brainiac/brainiac-completion.bash")
    FileUtils.cp(completion_file, target)
    puts "Installed to #{target}"
    puts "Add to your ~/.bashrc:"
    puts "  source #{target}"
  else
    puts File.read(completion_file)
  end

when "update", "upgrade"
  name = ARGV.shift

  if name
    # Update a specific plugin: brainiac update <plugin_name>
    name = name.sub(/^brainiac-/, "")
    gem_name = "brainiac-#{name}"

    # Verify plugin is installed
    plugins_file = File.join(BRAINIAC_DIR, "plugins.json")
    plugins_config = if File.exist?(plugins_file)
                       JSON.parse(File.read(plugins_file))
                     else
                       { "plugins" => [] }
                     end

    plugin_entry = (plugins_config["plugins"] || []).find { |p| (p.is_a?(Hash) ? p["name"] : p.to_s) == name }

    if plugin_entry.is_a?(Hash) && plugin_entry["path"]
      puts "Plugin '#{name}' is installed from a local path: #{plugin_entry["path"]}"
      puts "Local plugins are updated via git pull in their source directory."
      exit 0
    end

    unless plugin_entry
      puts "Plugin '#{name}' is not installed."
      puts "  Install it first: brainiac install #{name}"
      exit 1
    end

    # Get current version before update
    current_version = begin
      spec = Gem::Specification.find_by_name(gem_name)
      spec.version.to_s
    rescue Gem::MissingSpecError
      nil
    end

    puts "Updating #{gem_name}..."
    output, status = Open3.capture2e("gem install #{gem_name}")
    puts output
    unless status.success?
      puts ""
      puts "Failed to update #{gem_name}."
      exit 1
    end

    # Parse installed version from gem install output
    new_version = output[/Successfully installed #{Regexp.escape(gem_name)}-(\S+)/, 1]

    if new_version
      puts "✓ Updated #{gem_name}: #{current_version || "new"} → #{new_version}"
      puts "  Restart the server to activate: brainiac restart"
    else
      puts "✓ #{gem_name} is already at the latest version (#{current_version})"
    end
  else
    # Update brainiac itself: brainiac update
    current_version = BRAINIAC_VERSION

    puts "Updating brainiac gem..."
    output, status = Open3.capture2e("gem install brainiac")
    puts output
    unless status.success?
      puts ""
      puts "Failed to update brainiac."
      exit 1
    end

    # Parse installed version from gem install output
    new_version = output[/Successfully installed brainiac-(\S+)/, 1]

    if new_version
      puts "✓ Updated brainiac: #{current_version} → #{new_version}"
      puts "  Restart the server to apply: brainiac restart"
    else
      puts "✓ brainiac is already at the latest version (#{current_version})"
    end
  end

when "install"
  name = ARGV.shift
  unless name
    puts "Usage: brainiac install <plugin-name> [options]"
    puts ""
    puts "Installs a Brainiac plugin gem (brainiac-<name>) and registers it."
    puts ""
    puts "Options:"
    puts "  --path <dir>       Use a local gem directory (for development/private gems)"
    puts "  --version <ver>    Install a specific version from RubyGems"
    puts ""
    puts "Examples:"
    puts "  brainiac install whatsapp                            # from RubyGems"
    puts "  brainiac install fizzy --path ~/Code/brainiac-fizzy  # local dev"
    puts "  brainiac install slack --version 0.2.0               # specific version"
    puts ""
    puts "After installing, restart the server: brainiac restart"
    exit 1
  end

  # Strip "brainiac-" prefix if user includes it
  name = name.sub(/^brainiac-/, "")
  version = nil
  local_path = nil

  # Parse flags
  while ARGV.any?
    case ARGV[0]
    when "--version", "-v"
      ARGV.shift
      version = ARGV.shift
    when "--path", "-p"
      ARGV.shift
      local_path = File.expand_path(ARGV.shift || "")
    else
      break
    end
  end

  plugins_file = File.join(BRAINIAC_DIR, "plugins.json")
  plugins_config = if File.exist?(plugins_file)
                     JSON.parse(File.read(plugins_file))
                   else
                     { "plugins" => [] }
                   end

  existing = (plugins_config["plugins"] || []).find { |p| (p.is_a?(Hash) ? p["name"] : p.to_s) == name }
  if existing
    puts "Plugin '#{name}' is already installed."
    puts "  To reinstall: brainiac uninstall #{name} && brainiac install #{name}"
    exit 0
  end

  gem_name = "brainiac-#{name}"

  if local_path
    # Local path mode — validate the directory and register without gem install
    unless Dir.exist?(local_path)
      puts "Error: Path does not exist: #{local_path}"
      exit 1
    end

    entry_file = File.join(local_path, "lib", "brainiac_#{name}.rb")
    unless File.exist?(entry_file)
      puts "Error: Expected entry file not found: #{entry_file}"
      puts "  Plugin gems must have lib/brainiac_<name>.rb"
      exit 1
    end

    puts "Registering #{gem_name} from local path: #{local_path}"

    plugins_config["plugins"] ||= []
    entry = { "name" => name, "gem" => gem_name, "path" => local_path, "installed_at" => Time.now.iso8601 }
    plugins_config["plugins"] << entry

    ensure_brainiac_dir
    File.write(plugins_file, JSON.pretty_generate(plugins_config))

    update_handler_config(name, true)

    puts ""
    puts "✓ Registered plugin '#{name}' from #{local_path}"
    puts "  Restart the server to activate: brainiac restart"
    puts "  Note: Source changes take effect on next server restart."

    # Auto-run setup if plugin defines it and isn't already configured
    run_plugin_setup(name, local_path: local_path)
  else
    # RubyGems mode
    puts "Installing #{gem_name}..."

    install_cmd = "gem install #{gem_name}"
    install_cmd += " --version '#{version}'" if version

    system(install_cmd)
    unless $CHILD_STATUS.success?
      puts ""
      puts "Failed to install #{gem_name}."
      puts "  Check that the gem exists: https://rubygems.org/gems/#{gem_name}"
      exit 1
    end

    # Register in plugins.json
    plugins_config["plugins"] ||= []
    entry = { "name" => name, "gem" => gem_name, "installed_at" => Time.now.iso8601 }
    entry["version"] = version if version
    plugins_config["plugins"] << entry

    ensure_brainiac_dir
    File.write(plugins_file, JSON.pretty_generate(plugins_config))

    # Enable the handler
    update_handler_config(name, true)

    puts ""
    puts "✓ Installed plugin '#{name}' (#{gem_name})"
    puts "  Restart the server to activate: brainiac restart"

    # Auto-run setup if plugin defines it and isn't already configured
    run_plugin_setup(name)
  end

when "uninstall"
  name = ARGV.shift
  unless name
    puts "Usage: brainiac uninstall <plugin-name>"
    puts ""
    puts "Removes a Brainiac plugin from the configuration."
    puts "The gem itself remains installed (use 'gem uninstall brainiac-<name>' to fully remove)."
    exit 1
  end

  name = name.sub(/^brainiac-/, "")
  gem_name = "brainiac-#{name}"

  plugins_file = File.join(BRAINIAC_DIR, "plugins.json")
  unless File.exist?(plugins_file)
    puts "Plugin '#{name}' is not installed (no plugins.json found)."
    exit 1
  end

  plugins_config = JSON.parse(File.read(plugins_file))
  found = (plugins_config["plugins"] || []).any? { |p| (p.is_a?(Hash) ? p["name"] : p.to_s) == name }

  unless found
    puts "Plugin '#{name}' is not installed."
    exit 1
  end

  plugins_config["plugins"].reject! { |p| (p.is_a?(Hash) ? p["name"] : p.to_s) == name }
  File.write(plugins_file, JSON.pretty_generate(plugins_config))

  # Disable the handler
  update_handler_config(name, false)

  puts "✓ Removed plugin '#{name}' from Brainiac."
  puts "  The gem #{gem_name} is still installed system-wide."
  puts "  To fully remove: gem uninstall #{gem_name}"
  puts "  Restart the server to apply: brainiac restart"

when "plugins"
  plugins_cmd = ARGV.shift

  case plugins_cmd
  when "list", "ls", nil
    plugins_file = File.join(BRAINIAC_DIR, "plugins.json")
    plugins_config = if File.exist?(plugins_file)
                       JSON.parse(File.read(plugins_file))
                     else
                       { "plugins" => [] }
                     end

    plugins = plugins_config["plugins"] || []
    if plugins.empty?
      puts "No plugins installed."
      puts ""
      puts "Install plugins with: brainiac install <name>"
      puts "  Example: brainiac install whatsapp"
      puts "  Example: brainiac install fizzy --path ~/Code/brainiac-fizzy"
    else
      puts "Installed plugins:"
      plugins.each do |p|
        entry = p.is_a?(Hash) ? p : { "name" => p.to_s }
        name = entry["name"]
        gem_name = entry["gem"] || "brainiac-#{name}"
        local_path = entry["path"]
        installed_at = entry["installed_at"] ? " (#{entry["installed_at"][0..9]})" : ""

        if local_path
          # Local plugin — check path exists
          if Dir.exist?(local_path)
            puts "  ✓ #{name} → #{local_path}#{installed_at}"
          else
            puts "  ✗ #{name} → #{local_path} (path missing)#{installed_at}"
          end
        else
          # Gem plugin — check gem is loadable
          version = entry["version"] || "latest"
          loadable = begin
            spec = Gem::Specification.find_by_name(gem_name)
            "✓ #{name} (#{gem_name} #{spec.version})"
          rescue Gem::MissingSpecError
            "✗ #{name} (#{gem_name} — gem not found)"
          end
          puts "  #{loadable}#{installed_at}"
        end
      end
    end
  else
    puts "Usage: brainiac plugins [list]"
    puts ""
    puts "Managing plugins:"
    puts "  brainiac install <name>       Install a plugin"
    puts "  brainiac uninstall <name>     Remove a plugin"
    puts "  brainiac plugins              List installed plugins"
  end

when "plugin"
  plugin_cmd = ARGV.shift

  case plugin_cmd
  when "new"
    plugin_name = ARGV.shift
    unless plugin_name
      puts "Usage: brainiac plugin new <name>"
      puts ""
      puts "Generates a new Brainiac plugin gem skeleton."
      puts ""
      puts "Example:"
      puts "  brainiac plugin new slack"
      puts "  → Creates ~/Code/brainiac-slack/ with full gem structure"
      exit 1
    end

    plugin_name = plugin_name.downcase.gsub(/[^a-z0-9-]/, "-").sub(/^brainiac-/, "")
    gem_name = "brainiac-#{plugin_name}"
    pascal_name = plugin_name.split(/[-_]/).map(&:capitalize).join
    snake_name = plugin_name.tr("-", "_")

    # Determine output directory
    output_dir = ARGV.shift || File.join(Dir.pwd, gem_name)
    output_dir = File.expand_path(output_dir)

    if Dir.exist?(output_dir) && !Dir.empty?(output_dir)
      puts "Error: Directory already exists and is not empty: #{output_dir}"
      exit 1
    end

    puts "Creating #{gem_name} at #{output_dir}..."

    # Create directory structure
    dirs = [
      "lib/brainiac/plugins/#{plugin_name}",
      "test",
      "skills/#{plugin_name}"
    ]
    dirs.each { |d| FileUtils.mkdir_p(File.join(output_dir, d)) }

    # version.rb
    File.write(File.join(output_dir, "lib", "brainiac", "plugins", plugin_name, "version.rb"), <<~RUBY)
      # frozen_string_literal: true

      module Brainiac
        module Plugins
          module #{pascal_name}
            VERSION = "0.0.1"
          end
        end
      end
    RUBY

    # metadata.rb
    File.write(File.join(output_dir, "lib", "brainiac", "plugins", plugin_name, "metadata.rb"), <<~RUBY)
      # frozen_string_literal: true

      # Lightweight metadata — loaded by `brainiac help` without the full plugin runtime.

      require_relative "version"

      module Brainiac
        module Plugins
          module #{pascal_name}
            def self.configured?
              # TODO: Return true when the plugin has been configured
              false
            end

            def self.help_text
              "    brainiac #{plugin_name} <command>#{" " * [1, 20 - plugin_name.length].max}Manage #{pascal_name} integration"
            end
          end
        end
      end
    RUBY

    # cli.rb
    File.write(File.join(output_dir, "lib", "brainiac", "plugins", plugin_name, "cli.rb"), <<~RUBY)
      # frozen_string_literal: true

      require "json"

      module Brainiac
        module Plugins
          module #{pascal_name}
            module Cli
              BRAINIAC_DIR = ENV.fetch("BRAINIAC_DIR", File.join(Dir.home, ".brainiac"))

              class << self
                def run(args)
                  command = args.shift

                  case command
                  when "config"
                    cmd_config
                  when "setup"
                    cmd_setup
                  when "status"
                    cmd_status
                  else
                    print_help
                  end
                end

                private

                def cmd_config
                  puts "TODO: Show #{plugin_name} configuration"
                end

                def cmd_setup
                  puts "#{pascal_name} Setup"
                  puts "#{"=" * (pascal_name.length + 6)}"
                  puts ""
                  puts "TODO: Walk user through configuration"
                end

                def cmd_status
                  puts "TODO: Show #{plugin_name} status"
                end

                def print_help
                  puts <<~HELP
                    Usage: brainiac #{plugin_name} <command>

                    Commands:
                      config                              Show #{pascal_name} config
                      setup                               Interactive setup guide
                      status                              Check #{pascal_name} status via server API

                    Config file: #{File.join("~/.brainiac", "#{plugin_name}.json")}
                  HELP
                end
              end
            end

            def self.cli(args)
              Cli.run(args)
            end

            # Subcommand names for bash completion.
            def self.completions
              %w[config setup status]
            end
          end
        end
      end
    RUBY

    # Main plugin module
    File.write(File.join(output_dir, "lib", "brainiac", "plugins", "#{plugin_name}.rb"), <<~RUBY)
      # frozen_string_literal: true

      require_relative "#{plugin_name}/version"
      require_relative "#{plugin_name}/metadata"
      require_relative "#{plugin_name}/cli"

      module Brainiac
        module Plugins
          module #{pascal_name}
            class << self
              # Called by Brainiac plugin system during server startup.
              #
              # @param app [Sinatra::Application] The running Brainiac server
              def register(app)
                # TODO: Load config, register hooks, define routes, start threads
                setup_routes(app)

                LOG.info "[#{pascal_name}] Plugin registered"
              end

              private

              def setup_routes(app)
                app.get "/api/#{plugin_name}" do
                  content_type :json
                  { enabled: true }.to_json
                end

                # TODO: Define webhook route
                # app.post "/#{plugin_name}" do
                #   content_type :json
                #   { status: "received" }.to_json
                # end
              end
            end
          end
        end
      end
    RUBY

    # Entry point (loaded by RubyGems)
    File.write(File.join(output_dir, "lib", "brainiac_#{snake_name}.rb"), <<~RUBY)
      # frozen_string_literal: true

      # Brainiac #{pascal_name} Plugin — entry point loaded by RubyGems.
      require_relative "brainiac/plugins/#{plugin_name}"
    RUBY

    # Gemspec
    File.write(File.join(output_dir, "#{gem_name}.gemspec"), <<~RUBY)
      # frozen_string_literal: true

      require_relative "lib/brainiac/plugins/#{plugin_name}/version"

      Gem::Specification.new do |s|
        s.name        = "#{gem_name}"
        s.version     = Brainiac::Plugins::#{pascal_name}::VERSION
        s.summary     = "#{pascal_name} plugin for Brainiac"
        s.description = "#{pascal_name} integration for Brainiac — TODO: describe what this plugin does."
        s.authors     = ["Your Name"]
        s.homepage    = "https://github.com/yourorg/#{gem_name}"
        s.license     = "MIT"
        s.required_ruby_version = ">= 3.4"

        s.files = Dir["lib/**/*.rb", "README.md", "LICENSE"]
        s.require_paths = ["lib"]

        s.add_dependency "brainiac", ">= #{BRAINIAC_VERSION}"

        s.add_development_dependency "minitest", "~> 5.25"
        s.add_development_dependency "rake", "~> 13.0"
        s.add_development_dependency "rubocop", "~> 1.75"
        s.add_development_dependency "rubocop-performance", "~> 1.25"

        s.metadata["rubygems_mfa_required"] = "true"
      end
    RUBY

    # Gemfile
    File.write(File.join(output_dir, "Gemfile"), <<~RUBY)
      # frozen_string_literal: true

      source "https://rubygems.org"

      gemspec
    RUBY

    # Rakefile
    File.write(File.join(output_dir, "Rakefile"), <<~RUBY)
      # frozen_string_literal: true

      require "rake/testtask"
      require "rubocop/rake_task"

      Rake::TestTask.new(:test) do |t|
        t.libs << "test"
        t.libs << "lib"
        t.test_files = FileList["test/**/test_*.rb"]
      end

      RuboCop::RakeTask.new(:rubocop)

      task default: %i[test rubocop]
    RUBY

    # .rubocop.yml
    File.write(File.join(output_dir, ".rubocop.yml"), <<~YAML)
      plugins:
        - rubocop-performance

      AllCops:
        TargetRubyVersion: 3.4
        NewCops: enable
        SuggestExtensions: false
        Exclude:
          - "vendor/**/*"
          - "tmp/**/*"

      Metrics/MethodLength:
        Max: 75

      Metrics/AbcSize:
        Max: 90

      Metrics/ModuleLength:
        Max: 600

      Metrics/ParameterLists:
        Max: 10
        CountKeywordArgs: false

      Metrics/BlockLength:
        Exclude:
          - "test/**/*"
          - "*.gemspec"

      Style/TopLevelMethodDefinition:
        Enabled: false

      Style/StringLiterals:
        EnforcedStyle: double_quotes

      Style/FrozenStringLiteralComment:
        Enabled: false

      Style/ClassAndModuleChildren:
        Enabled: false

      Style/Documentation:
        Enabled: false

      Gemspec/DevelopmentDependencies:
        Enabled: false

      Layout/LineLength:
        Max: 150

      Naming/PredicateMethod:
        Enabled: false

      Naming/FileName:
        Exclude:
          - "lib/brainiac/plugins/**/*"
    YAML

    # Test helper
    File.write(File.join(output_dir, "test", "test_helper.rb"), <<~RUBY)
      # frozen_string_literal: true

      require "minitest/autorun"
      require "json"
      require "fileutils"
      require "tmpdir"

      TEST_BRAINIAC_DIR = Dir.mktmpdir("brainiac-#{plugin_name}-test")
      ENV["BRAINIAC_DIR"] = TEST_BRAINIAC_DIR

      unless defined?(LOG)
        LOG = Class.new do
          def info(_msg) = nil
          def warn(_msg) = nil
          def error(_msg) = nil
          def debug(_msg) = nil
          def debug? = false
        end.new
      end

      module Brainiac
        @hooks = Hash.new { |h, k| h[k] = [] }
        @channel_prompts = {}
        @channel_pre_post_checks = {}

        class << self
          def on(event, &block) = @hooks[event] << block

          def emit(event, **ctx)
            @hooks[event].filter_map do |h|
              h.call(ctx)
            rescue StandardError
              nil
            end
          end

          def register_channel_prompt(channel, prompt, pre_post_check: nil)
            @channel_prompts[channel] = prompt
            @channel_pre_post_checks[channel] = pre_post_check if pre_post_check
          end

          attr_reader :hooks, :channel_prompts, :channel_pre_post_checks

          def reset_hooks!
            @hooks = Hash.new { |h, k| h[k] = [] }
            @channel_prompts = {}
            @channel_pre_post_checks = {}
          end
        end

        module Plugins; end
      end

      AGENT_REGISTRY = {}.freeze
      PROJECTS = {}.freeze

      require_relative "../lib/brainiac_#{snake_name}"

      Minitest.after_run { FileUtils.rm_rf(TEST_BRAINIAC_DIR) }
    RUBY

    # Test file
    File.write(File.join(output_dir, "test", "test_#{snake_name}.rb"), <<~RUBY)
      # frozen_string_literal: true

      require_relative "test_helper"

      class Test#{pascal_name}Plugin < Minitest::Test
        def test_register_method_exists
          assert_respond_to Brainiac::Plugins::#{pascal_name}, :register
        end

        def test_version_defined
          assert_match(/\\A\\d+\\.\\d+\\.\\d+\\z/, Brainiac::Plugins::#{pascal_name}::VERSION)
        end

        def test_cli_method_exists
          assert_respond_to Brainiac::Plugins::#{pascal_name}, :cli
        end

        def test_configured_returns_boolean
          result = Brainiac::Plugins::#{pascal_name}.configured?
          assert_includes [true, false], result
        end

        def test_help_text_defined
          text = Brainiac::Plugins::#{pascal_name}.help_text
          assert_kind_of String, text
          assert_includes text, "brainiac #{plugin_name}"
        end
      end
    RUBY

    # README
    File.write(File.join(output_dir, "README.md"), <<~MD)
      # #{gem_name}

      #{pascal_name} plugin for [Brainiac](https://github.com/stowzilla/brainiac).

      ## Installation

      ```bash
      brainiac install #{plugin_name}
      brainiac restart
      ```

      Or for local development:

      ```bash
      brainiac install #{plugin_name} --path #{output_dir}
      brainiac restart
      ```

      ## Configuration

      ```bash
      brainiac #{plugin_name} setup
      ```

      ## Development

      ```bash
      bundle install
      rake test
      rake rubocop
      ```

      ## License

      MIT
    MD

    # Plugin development SKILL.md — stamped into the scaffold so agents
    # working on this plugin know the contract without needing brain access.
    File.write(File.join(output_dir, "skills", plugin_name, "SKILL.md"),
               generate_plugin_skill_md(plugin_name, pascal_name))

    puts ""
    puts "✓ Created #{gem_name} at #{output_dir}"
    puts ""
    puts "Next steps:"
    puts "  cd #{output_dir}"
    puts "  bundle install"
    puts "  rake test                    # Verify scaffold works"
    puts "  # Edit lib/brainiac/plugins/#{plugin_name}.rb to add your logic"
    puts "  brainiac install #{plugin_name} --path #{output_dir}"
    puts "  brainiac restart"

  else
    puts "Usage: brainiac plugin <command>"
    puts ""
    puts "Commands:"
    puts "  new <name>                   Generate a new plugin gem skeleton"
    puts ""
    puts "Managing installed plugins:"
    puts "  brainiac install <name>      Install a plugin"
    puts "  brainiac uninstall <name>    Remove a plugin"
    puts "  brainiac plugins             List installed plugins"
  end

when "version", "--version", "-v"
  puts "brainiac #{BRAINIAC_VERSION}"

when "help", "--help", "-h", nil
  # Load installed plugin help dynamically
  plugin_help_lines = collect_plugin_help_lines

  plugin_section = if plugin_help_lines.any?
                     "\n    Installed Plugins:\n#{plugin_help_lines.join("\n")}\n"
                   else
                     ""
                   end

  puts <<~HELP
      Brainiac CLI - Manage projects with Brainiac server

      Usage:
        brainiac setup                  Bootstrap a new machine (deps, dirs, configs)
        brainiac server [options]       Start the Brainiac webhook server (foreground)
        brainiac stop                   Stop the running server
        brainiac restart                Restart the server
        brainiac logs                   Tail the server log
        brainiac status                 Check if server is running
        brainiac register [options]     Register current directory as a project
        brainiac unregister <key>       Unregister a project
        brainiac list                   List all registered projects
        brainiac projects list          List all registered projects (alias)
        brainiac projects default <key> Set the default project
        brainiac show <key>             Show project configuration
        brainiac plugin new <name>      Generate a new plugin gem skeleton
        brainiac update                  Update brainiac to the latest version
        brainiac update <plugin>        Update an installed plugin to the latest version
        brainiac install <plugin>       Install a Brainiac plugin (gem-based handler)
        brainiac uninstall <plugin>     Remove an installed plugin
        brainiac plugins                List installed plugins
        brainiac brain <command>        Manage agent long-term memory (brain)
        brainiac cron <command>         Manage scheduled agent tasks
        brainiac provider <command>     Manage CLI providers
        brainiac role <command>         Manage agent roles
        brainiac agent <command>        Manage agent registry (env, list, show)
        brainiac config                 Configure Brainiac CLI
        brainiac path                   Show Brainiac config directory
        brainiac version                Show version
        brainiac help                   Show this help message
    #{plugin_section}
      Server Options:
        -d, --daemon                     Run server in background (detached)

      Plugin Commands:
        plugin new <name>                Generate a new plugin gem skeleton
        install <name>                   Install a plugin (gem install brainiac-<name>)
        uninstall <name>                 Remove a plugin
        update [name]                    Update brainiac or a specific plugin
        plugins                          List installed plugins

      Card Map Commands:
        card-map list                    Show all card map entries
        card-map clean                   Remove stale entries (missing worktrees)

      Brain Commands:
        brain init [agent]               Initialize brain (knowledge + persona)
        brain status [agent]             Show brain status and files
        brain search [--persona] <q>     Search knowledge or persona
        brain list                       List knowledge and all personas
        brain path                       Show knowledge directory

      Cron Commands:
        cron add -s <schedule> -p <project> "<prompt>"
                                         Add a scheduled task
        cron list                        List all cron jobs
        cron remove <job-id>             Remove a cron job
        cron enable <job-id>             Enable a cron job
        cron disable <job-id>            Disable a cron job
        cron update <job-id> -s <schedule>
                                         Update a cron job's schedule

      Provider Commands:
        provider list                    List configured CLI providers
        provider show <name>             Show provider configuration
        provider add <name>              Create a new provider config

      Role Commands:
        role list                        List configured roles and assignments
        role show <name>                 Show role definition
        role create <name>               Create a new role file
        role assign <agent> <role>       Assign a role to an agent (additive)
        role unassign <agent> <role>     Remove a role from an agent

      Agent Commands:
        agent list                         List all agents in the registry
        agent <name> show                  Show agent configuration (tokens redacted)
        agent <name> env <KEY> <VALUE>     Set an env var for an agent
        agent <name> env                   List env vars for an agent
        agent <name> env --delete <KEY>    Remove an env var from an agent

      Examples:
        # Start the server in the foreground (like rails server)
        brainiac server
        brainiac s
      #{"  "}
        # Register current directory
        cd ~/Code/my-project && brainiac register
      #{"  "}
        # Install a plugin
        brainiac install discord
      #{"  "}
        # List all projects
        brainiac list

      Configuration:
        Projects are stored in: #{BRAINIAC_DIR}/projects.json
        Server config: #{BRAINIAC_DIR}/config.json
        Brain storage: #{BRAINIAC_DIR}/brain/
  HELP

else
  # Check if the subcommand matches an installed plugin (e.g. "brainiac discord ...")
  plugins_file = File.join(BRAINIAC_DIR, "plugins.json")
  plugins_config = File.exist?(plugins_file) ? JSON.parse(File.read(plugins_file)) : { "plugins" => [] }
  (plugins_config["plugins"] || []).map { |p| p.is_a?(Hash) ? p["name"] : p.to_s }
  plugin_entry = (plugins_config["plugins"] || []).find { |p| (p.is_a?(Hash) ? p["name"] : p.to_s) == subcommand }

  if plugin_entry
    # Delegate to the plugin's CLI module
    gem_name = "brainiac-#{subcommand}"
    begin
      if plugin_entry.is_a?(Hash) && plugin_entry["path"]
        lib_path = File.join(plugin_entry["path"], "lib")
        $LOAD_PATH.unshift(lib_path) unless $LOAD_PATH.include?(lib_path)
      end

      # Try lightweight CLI loading first (metadata + cli only, no server runtime)
      cli_loaded = try_require_plugin_cli(subcommand, plugin_entry)

      # Fall back to full gem load if no standalone CLI file exists
      unless cli_loaded
        begin
          require gem_name
        rescue LoadError
          require gem_name.tr("-", "_")
        end
      end

      # Resolve the plugin module and call .cli(ARGV)
      mod = resolve_plugin_module_for(subcommand)

      if mod.respond_to?(:cli)
        mod.cli(ARGV)
      else
        puts "Plugin '#{subcommand}' is installed but does not provide CLI commands."
        puts "It runs as a server plugin — use 'brainiac server' to activate it."
      end
    rescue LoadError => e
      puts "Plugin '#{subcommand}' is registered but could not be loaded: #{e.message}"
      puts "Try reinstalling: brainiac uninstall #{subcommand} && brainiac install #{subcommand}"
      exit 1
    end
  else
    puts "Unknown command: #{subcommand}"
    puts "Run 'brainiac help' for usage information."
    exit 1
  end
end
